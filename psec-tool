def _gen_work_keylib_once(kbpk: bytes, version_id: VersionId) -> tuple[bytes, bytes]:
    """Derive KBEK/KBAK for a single version via the psec library."""
    _method = {
        VersionId.A: "_c_derive", VersionId.B: "_b_derive",
        VersionId.C: "_c_derive", VersionId.D: "_d_derive",
        VersionId.E: "_e_derive",
    }
    kb = psec.tr31.KeyBlock(
        kbpk=kbpk, header=psec.tr31.Header(version_id=version_id),
    )
    return getattr(kb, _method[version_id])()


def cmd_tr31_kbpk(args: argparse.Namespace) -> None:
    kbpk = bytes.fromhex(args.kbpk)
    print(f"kbpk: {kbpk.hex().upper()} ({len(kbpk)} bytes)")
    for v in _VERSIONS.values():
        print(f"version {v.version_id} ({v.description}):")
        try:
            kbek, kbak = _gen_work_keylib_once(kbpk, v.version_id)
            print(f"  kbek: {kbek.hex().upper()}")
            print(f"  kbak: {kbak.hex().upper()}")
        except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
            print(f"  n/a: {e}")


# ---------------------------------------------------------------------------
# cmac-k1k2
# ---------------------------------------------------------------------------

def _derive_cmac_subkey_once(key: bytes, cipher: Algorithm) -> tuple[bytes, bytes]:
    """Derive CMAC subkeys K1, K2 for a single cipher algorithm.

    Parameters
    ----------
    key : bytes
        The key to derive CMAC subkeys from.
    cipher : Algorithm
        ``Algorithm.TDES`` or ``Algorithm.AES``.

    Returns
    -------
    k1, k2 : tuple[bytes, bytes]
    """
    method = "_derive_des_cmac_subkey" if cipher is Algorithm.TDES else "_derive_aes_cmac_subkey"
    kb = psec.tr31.KeyBlock(kbpk=b"\x00" * 16)
    return getattr(kb, method)(key)


# CMAC subkeys K1/K2 (NIST SP 800-38B). These are a low-level primitive:
# K1/K2 = shift-left-1 of E_K(0), conditionally XOR'd with Rb
# (Rb = ...1B for DES 8-byte blocks, ...87 for AES 16-byte blocks).
#
# These subkeys are NOT the KBEK/KBAK themselves; they are a building
# block used *inside* the KBEK/KBAK derivation (see `tr31 kbpk`):
#
#   Version B (TDES) / D / E (AES) key derivation:
#     1. Derive CMAC subkeys from the KBPK:
#          DES: K1, _ = _derive_des_cmac_subkey(kbpk)   (uses K1)
#          AES: _, K2 = _derive_aes_cmac_subkey(kbpk)   (uses K2)
#     2. Build a derivation input block carrying:
#          counter | usage (enc/mac) | 00 | algo | key-bits | pad
#     3. XOR that input with the subkey (K1 for DES, K2 for AES) and
#        run it through CBC-MAC under KBPK (IV=0 → ECB on one block).
#        Each pass yields 64 bits (DES) or 128 bits (AES) of key material.
#     4. Concatenate passes (incrementing counter) until enough bits:
#          usage_enc → KBEK   usage_mac → KBAK
#     5. Truncate to KBPK length.
#
#   The KBAK is then itself fed through the CMAC-subkey step again when
#   generating the final key-block MAC (the last MAC-data block is XOR'd
#   with K1 of the KBAK before the CBC-MAC pass).
#
#   Version A/C do NOT use CMAC subkeys at all; they derive KBEK/KBAK by
#   XOR'ing the KBPK with the constants 0x45.. / 0x4D.. (variant method).


def cmd_tr31_cmac_k1k2(args: argparse.Namespace) -> None:
    key = bytes.fromhex(args.key)
    print(f"key: {key.hex().upper()} ({len(key)} bytes)")
    for algo in Algorithm:
        print(f"{algo}:")
        try:
            k1, k2 = _derive_cmac_subkey_once(key, algo)
            print(f"  k1: {k1.hex().upper()}")
            print(f"  k2: {k2.hex().upper()}")
        except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
            print(f"  n/a: {e}")


# ---------------------------------------------------------------------------
# cmac
# ---------------------------------------------------------------------------

def _cmac_once(key: bytes, data: bytes, cipher: Algorithm) -> bytes:
    """Compute CMAC (NIST SP 800-38B) tag over ``data``.

    Parameters
    ----------
    key : bytes
        The CMAC key.
    data : bytes
        Data to authenticate.
    cipher : Algorithm
        ``Algorithm.TDES`` or ``Algorithm.AES``.

    Returns
    -------
    mac : bytes
        CMAC tag (8 bytes for TDES, 16 bytes for AES).
    """
    block_size = cipher.block_size
    k1, k2 = _derive_cmac_subkey_once(key, cipher)

    remainder = len(data) % block_size
    if remainder != 0 or len(data) == 0:
        data = psec.mac.pad_iso_2(data, block_size)
        last_subkey = k2
    else:
        last_subkey = k1

    data = data[:-block_size] + psec.tools.xor(data[-block_size:], last_subkey)
    return psec.mac.generate_cbc_mac(key, data, 1, block_size, cipher.mac_algorithm)


def cmd_tr31_cmac(args: argparse.Namespace) -> None:
    key = bytes.fromhex(args.key)
    data = bytes.fromhex(args.data)
    mac = _cmac_once(key, data, Algorithm(args.algo))
    print(mac.hex().upper())


# ---------------------------------------------------------------------------
# padding
# ---------------------------------------------------------------------------

_VERSION_BLOCK_SIZE = {
    "A": 8, "B": 8, "C": 8, "D": 16,
}


def _build_padded(version: str, payload: bytes,
                  masked_key_len: int | None = None) -> tuple[bytes, int, int]:
    """Build ``key_len_bits(2) + payload + padding`` .

    Returns ``(padded, pad_len, extra_pad)``.
    Padding is zero-filled for deterministic display
    (actual TR-31 uses ``os.urandom``).
    """
    block_size = _VERSION_BLOCK_SIZE.get(version)
    actual_len = len(payload)
    target_len = max(actual_len, masked_key_len or actual_len)
    extra_pad = target_len - actual_len
    overhead = 2  # key-len-bits

    if block_size is None:
        pad_len = 0
    else:
        remainder = (overhead + actual_len + extra_pad) % block_size
        pad_len = block_size - remainder if remainder != 0 else 0

    key_len_bits = (len(payload) * 8).to_bytes(2, "big")
    padding = b"\x00" * (pad_len + extra_pad)
    return (key_len_bits + payload + padding, pad_len, extra_pad)


def cmd_tr31_padding(args: argparse.Namespace) -> None:
    """Show the key-data block that TR-31 feeds to encryption.

    TR-31 key data layout::

         2 bytes  key-length in bits (big-endian)
         N bytes  the actual key / payload
         M bytes  random padding that fills to the version's block size
                   + optional extra masking bytes (``-m masked_key_len``)

    The prefix encodes the real key length so the decryptor knows
    exactly where the key ends; everything after the prefix + key is
    padding and is discarded on unwrap.

    Version E (AES-CTR) does not require block-alignment padding.
    """
    payload = bytes.fromhex(args.payload)
    padded, pad_len, extra_pad = _build_padded(args.version, payload, args.masked_key_len)

    key_len_bits = padded[:2]
    block_size = _VERSION_BLOCK_SIZE.get(args.version)
    total_pad = pad_len + extra_pad

    print(f"version:        {args.version}  ({_VERSION_ID_TABLE[args.version]})")
    if extra_pad:
        print(f"masked_key_len: {args.masked_key_len} bytes  (real: {len(payload)} bytes)")
    if block_size is not None:
        print(f"block_size:     {block_size} bytes")
    else:
        print(f"mode:           AES-CTR (no padding required)")
    print(f"key-len-bits:   {key_len_bits.hex().upper()} (2 bytes)")
    print(f"payload:        {payload.hex().upper()} ({len(payload)} bytes)")
    print(f"pad_len:        {pad_len} bytes  (block alignment)")
    print(f"extra_pad:      {extra_pad} bytes  (length masking)")
    print(f"total_pad:      {total_pad} bytes")
    print()
    print(f"  [key-len-bits]:       {key_len_bits.hex().upper()}")
    print(f"  [payload]:            {payload.hex().upper()}")
    if total_pad > 0:
        print(f"  [padding]:            {padded[len(key_len_bits)+len(payload):].hex().upper()}")
    print(f"  clear_key_data:       {padded.hex().upper()}")


# ---------------------------------------------------------------------------
# unpadding
# ---------------------------------------------------------------------------

def cmd_tr31_unpadding(args: argparse.Namespace) -> None:
    """Unwrap the key from a TR-31 clear-key-data block.

    Reads the 2-byte key-length-in-bits prefix, extracts that many
    bytes as the real key, and shows the padding tail.
    """
    data = bytes.fromhex(args.clear_key_data)

    if len(data) < 2:
        print("error: clear_key_data must be at least 2 bytes", file=sys.stderr)
        sys.exit(1)

    key_len_bits = int.from_bytes(data[:2], "big")
    key_len_bytes = key_len_bits // 8
    key = data[2: 2 + key_len_bytes]
    padding = data[2 + key_len_bytes:]

    if key_len_bits % 8 != 0:
        print(f"warning: key-length {key_len_bits} bits is not a whole number of bytes",
              file=sys.stderr)

    version_desc = _VERSION_ID_TABLE.get(args.version, "proprietary")
    print(f"version:        {args.version}  ({version_desc})")
    print(f"key-len-bits:   {data[:2].hex().upper()}  => {key_len_bits} bits = {key_len_bytes} bytes")
    print(f"key:            {key.hex().upper()} ({len(key)} bytes)")
    print(f"padding:        {padding.hex().upper()} ({len(padding)} bytes)")
    if len(key) != key_len_bytes:
        print(f"warning: data truncated (expected {key_len_bytes} bytes, got {len(key)})",
              file=sys.stderr)


# ---------------------------------------------------------------------------
# derive-data
# ---------------------------------------------------------------------------

@dataclass
class DeriveBlock:
    """One derivation input block (one counter × usage pair)."""
    counter: int
    usage_label: str         # "enc" or "mac"
    raw: bytes               # unpadded derivation input
    padded: bytes            # ISO-9797-1 method-2 padded block (or raw if none needed)
    has_padding: bool        # True when ISO padding was applied


@dataclass
class DeriveData:
    """All derivation blocks for one ``VersionCfg``."""
    vc: VersionCfg
    blocks: dict[str, list[DeriveBlock]]  # "enc" | "mac" -> list of DeriveBlock


def _derive_data_blocks_once(vc: VersionCfg) -> dict[str, list[DeriveBlock]]:
    """Derive input data blocks for a single ``VersionCfg``.

    Returns ``{"enc": [...], "mac": [...]}`` — one ``DeriveBlock`` per
    counter/usage pair, carrying both the raw (unpadded) derivation
    input and the ISO-9797-1 method-2 padded variant.
    """
    v, cfg = _lookup(vc)
    blocks: dict[str, list[DeriveBlock]] = {"enc": [], "mac": []}
    for counter in cfg.counters:
        for usage_label, usage in [("enc", v.usage_enc),
                                   ("mac", v.usage_mac)]:
            raw_data = bytes([counter]) + usage + b"\x00" + cfg.algo + cfg.keybits
            pad = v.block_size - (len(raw_data) % v.block_size)
            has_padding = pad != v.block_size
            padded = psec.mac.pad_iso_2(raw_data, v.block_size) if has_padding else raw_data
            blocks[usage_label].append(DeriveBlock(
                counter=counter,
                usage_label=usage_label,
                raw=raw_data,
                padded=padded,
                has_padding=has_padding,
            ))
    return blocks


def do_tr31_derive_data() -> list[DeriveData]:
    result: list[DeriveData] = []
    for version_id, v in _VERSIONS.items():
        if v.method != "cmac":
            continue
        for kbpk_bytes in v.kbpk_configs:
            vc = VersionCfg(version_id, kbpk_bytes)
            result.append(DeriveData(vc=vc, blocks=_derive_data_blocks_once(vc)))
    return result


def cmd_tr31_derive_data(args: argparse.Namespace) -> None:
    for d in do_tr31_derive_data():
        v, cfg = _lookup(d.vc)
        print(
            f"version {v.version_id} | cipher={v.algorithm} | "
            f"{cfg.description} | kbpk={cfg.kbpk_bytes}bytes | "
            f"subkey={v.subkey} | calls={len(cfg.counters)}"
        )
        print(f"  block_size={v.block_size}")
        print(f"    algo={cfg.algo.hex().upper()}  keybits={cfg.keybits.hex().upper()}")
        for b in d.blocks["enc"]:
            print(
                f"      counter={b.counter}  "
                f"usage_enc=({v.usage_enc.hex().upper()}): "
                f"=> {b.padded.hex().upper()}"
            )
        for b in d.blocks["mac"]:
            print(
                f"      counter={b.counter}  "
                f"usage_mac=({v.usage_mac.hex().upper()}): "
                f"=> {b.padded.hex().upper()}"
            )


# ---------------------------------------------------------------------------
# manual KBEK/KBAK derivation (via cmac / xvariant)
# ---------------------------------------------------------------------------

@dataclass
class CmacWorkKeyResult(WorkKeyResult):
    subkey_name: str = ""
    subkey: bytes = b""
    passes: dict[str, list[dict[str, bytes]]] = field(
        default_factory=lambda: {"enc": [], "mac": []},
    )
    # "enc" | "mac" -> list of {"xor": ..., "cmac": ...} per counter


def _gen_work_keycmac_once(kbpk: bytes, version_id: VersionId) -> CmacWorkKeyResult:
    """Derive KBEK/KBAK for a single CMAC version.

    Applies standard NIST CMAC to the raw (unpadded) derivation input
    blocks obtained from ``_derive_data_blocks_once``.
    """
    vc = VersionCfg(version_id, len(kbpk))
    v, cfg = _lookup(vc)
    assert v.algorithm is not None
    k1, k2 = _derive_cmac_subkey_once(kbpk, v.algorithm)

    data_blocks = _derive_data_blocks_once(vc)

    trace = CmacWorkKeyResult(
        version_id=v.version_id,
        description=cfg.description,
        subkey_name=v.subkey,
        subkey=k1 if v.subkey == "K1" else k2,
    )
    result = trace
    workkey: dict[str, bytes] = {"enc": b"", "mac": b""}
    for usage_label in ("enc", "mac"):
        for b in data_blocks[usage_label]:
            pass_bytes = _cmac_once(kbpk, b.raw, v.algorithm)

            last_subkey = k2 if b.has_padding else k1
            xor_bytes = psec.tools.xor(b.padded, last_subkey)

            trace.passes[usage_label].append({"xor": xor_bytes, "cmac": pass_bytes})
            workkey[usage_label] += pass_bytes

    for v in workkey.values():
        assert len(v) >= len(kbpk)
    result.kbek = workkey["enc"][:len(kbpk)]
    result.kbak = workkey["mac"][:len(kbpk)]
    return result


def do_tr31_gen_work_key_cmac(kbpk: bytes) -> dict[VersionId, CmacWorkKeyResult]:
    acc: dict[VersionId, CmacWorkKeyResult] = {}
    for version_id, v in _VERSIONS.items():
        if v.method != "cmac":
            continue
        if len(kbpk) not in v.kbpk_configs:
            continue
        acc[version_id] = _gen_work_keycmac_once(kbpk, version_id)
    return acc


def _gen_work_keyxvariant_once(kbpk: bytes, version_id: VersionId) -> WorkKeyResult:
    """Derive KBEK/KBAK for a single XOR-variant version."""
    v = _VERSIONS[version_id]
    bek = psec.tools.xor(kbpk, b"\x45" * len(kbpk))
    bak = psec.tools.xor(kbpk, b"\x4D" * len(kbpk))
    return WorkKeyResult(version_id, v.description, kbek=bek, kbak=bak)


def do_tr31_gen_work_key_xvariant(kbpk: bytes) -> dict[VersionId, WorkKeyResult]:
    rows: dict[VersionId, WorkKeyResult] = {}
    for v in _VERSIONS.values():
        if v.method != "xvariant":
            continue
        rows[v.version_id] = _gen_work_keyxvariant_once(kbpk, v.version_id)
    return rows


# ---------------------------------------------------------------------------
# kbek-kbak  (compare manual derivation with library)
# ---------------------------------------------------------------------------

def cmd_tr31_kbek_kbak(args: argparse.Namespace) -> None:
    kbpk = bytes.fromhex(args.kbpk)
    print(f"kbpk: {kbpk.hex().upper()} ({len(kbpk)} bytes)\n")

    cmac = do_tr31_gen_work_key_cmac(kbpk)
    xvariant = do_tr31_gen_work_key_xvariant(kbpk)

    for version_id, r in cmac.items():
        print(f"version {r.version_id} | {r.description}:")
        print(f"  {r.subkey_name} -> {r.subkey.hex().upper()}")
        for usage_label in ("enc", "mac"):
            for i, p in enumerate(r.passes[usage_label], 1):
                print(f"  kd[{i}]{usage_label}: {p['xor'].hex().upper()}  --CMAC--> {p['cmac'].hex().upper()}")
        print(f"  => kbek: {r.kbek.hex().upper()}")
        print(f"  => kbak: {r.kbak.hex().upper()}")

        try:
            l_kbek, l_kbak = _gen_work_keylib_once(kbpk, version_id)
            ok_bek = "(OK)" if r.kbek == l_kbek else "(MISMATCH)"
            ok_bak = "(OK)" if r.kbak == l_kbak else "(MISMATCH)"
            print(f"     lib kbek: {l_kbek.hex().upper()}  {ok_bek}")
            print(f"     lib kbak: {l_kbak.hex().upper()}  {ok_bak}")
        except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
            print(f"     lib: n/a  ({e})")
        print()

    for version_id, r in xvariant.items():
        try:
            l_kbek, l_kbak = _gen_work_keylib_once(kbpk, version_id)
        except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError):
            continue
        print(f"version {r.version_id} | XOR variant:")
        ok_bek = "(OK)" if r.kbek == l_kbek else "(MISMATCH)"
        ok_bak = "(OK)" if r.kbak == l_kbak else "(MISMATCH)"
        print(f"  => kbek: {r.kbek.hex().upper()}  {ok_bek}  (kbpk ^ 0x45..45)")
        print(f"  => kbak: {r.kbak.hex().upper()}  {ok_bak}  (kbpk ^ 0x4D..4D)\n")


# ---------------------------------------------------------------------------
# wrap-verbose  (verbose TR-31 key wrap, versions A-E)
# ---------------------------------------------------------------------------

def _wrapv_build_header(hdr: "psec.tr31.Header", masked_key_len: int) -> str:
    """Build the final header string via Header.dump()."""
    return hdr.dump(masked_key_len)


def _wrapv_resolve_masked_len(key: bytes, algorithm: str,
                              masked_key_len: int | None) -> int:
    if masked_key_len is None:
        default_max = 24 if algorithm == "T" or algorithm == "D" else 32
        return max(default_max, len(key))
    return max(masked_key_len, len(key))


def _wrapv_clear_key(key: bytes, extra_pad: int, block_size: int,
                     padding_mode: str = "zero") -> tuple[bytes, int, int, bytes, bytes]:
    """Build clear key data: key_len_bits(2) + key + padding.

    Returns (clear_key_data, pad_len, total_pad, key_len_bits, padding_bytes).
    Block alignment padding is only applied when block_size > 0.

    padding_mode:
      "zero"   - zero-fill (deterministic, shows structure)
      "random" - os.urandom (matches library default)
    """
    import os
    key_len_bits = (len(key) * 8).to_bytes(2, "big")
    if block_size > 0:
        pad_len = block_size - ((2 + len(key) + extra_pad) % block_size)
    else:
        pad_len = 0
    total_pad = pad_len + extra_pad
    if padding_mode == "random":
        padding = os.urandom(total_pad)
    else:
        padding = b"\x00" * total_pad
    return key_len_bits + key + padding, pad_len, total_pad, key_len_bits, padding


# ---------------------------------------------------------------------------
# Version A / C: TDES variant (XOR keys + CBC-MAC-on-enc-key)
# ---------------------------------------------------------------------------


def _wrapv_ac(kbpk: bytes, header_dump: str, key: bytes, extra_pad: int,
              padding_mode: str = "zero") -> dict[str, object]:
    img: dict[str, object] = {}

    variant_enc = b"\x45" * len(kbpk)
    variant_mac = b"\x4D" * len(kbpk)
    kbek = psec.tools.xor(kbpk, variant_enc)
    kbak = psec.tools.xor(kbpk, variant_mac)
    img["method"] = "variant"
    img["variant_enc"] = variant_enc
    img["variant_mac"] = variant_mac
    img["kbek"] = kbek
    img["kbak"] = kbak

    clear_key_data, pad_len, total_pad, key_len_bits, padding = _wrapv_clear_key(
        key, extra_pad, 8, padding_mode,
    )
    img["key_len_bits"] = key_len_bits
    img["pad_len"] = pad_len
    img["total_pad"] = total_pad
    img["clear_key_data"] = clear_key_data

    iv = header_dump.encode("ascii")[:8]
    enc_key = psec.des.encrypt_tdes_cbc(kbek, iv, clear_key_data)
    img["iv"] = iv
    img["enc_key"] = enc_key

    mac_data = header_dump.encode("ascii") + enc_key
    mac = psec.mac.generate_cbc_mac(kbak, mac_data, 1, 4, psec.mac.Algorithm.DES)
    img["mac"] = mac
    img["mac_data_bytes"] = mac_data

    img["key_block"] = header_dump + enc_key.hex().upper() + mac.hex().upper()
    return img


# ---------------------------------------------------------------------------
# Version B: TDES CMAC derivation + TDES-CBC (MAC as IV)
# ---------------------------------------------------------------------------


def _wrapv_b(kbpk: bytes, header_dump: str, key: bytes, extra_pad: int,
             padding_mode: str = "zero") -> dict[str, object]:
    img: dict[str, object] = {}
    cmac_r = _gen_work_keycmac_once(kbpk, VersionId.B)
    kbek, kbak = cmac_r.kbek, cmac_r.kbak
    img["method"] = "cmac"
    img["algorithm"] = Algorithm.TDES
    img["subkey_name"] = cmac_r.subkey_name
    img["subkey"] = cmac_r.subkey
    img["kbek"] = kbek
    img["kbak"] = kbak
    img["cmac_passes"] = cmac_r.passes

    clear_key_data, pad_len, total_pad, key_len_bits, padding = _wrapv_clear_key(
        key, extra_pad, 8, padding_mode,
    )
    img["key_len_bits"] = key_len_bits
    img["pad_len"] = pad_len
    img["total_pad"] = total_pad
    img["clear_key_data"] = clear_key_data

    k1, _ = psec.tr31.KeyBlock(kbpk=b"\x00" * 16)._derive_des_cmac_subkey(kbak)
    mac_data_full = header_dump.encode("ascii") + clear_key_data
    mac_data_xor = mac_data_full[:-8] + psec.tools.xor(mac_data_full[-8:], k1)
    mac = psec.mac.generate_cbc_mac(kbak, mac_data_xor, 1, 8, psec.mac.Algorithm.DES)
    img["mac_k1"] = k1
    img["mac_data_full"] = mac_data_full
    img["mac_data_xor"] = mac_data_xor
    img["mac"] = mac

    enc_key = psec.des.encrypt_tdes_cbc(kbek, mac, clear_key_data)
    img["iv_mac"] = mac
    img["enc_key"] = enc_key

    img["key_block"] = header_dump + enc_key.hex().upper() + mac.hex().upper()
    return img


# ---------------------------------------------------------------------------
# Version D: AES CMAC derivation + AES-CBC (MAC as IV)
# ---------------------------------------------------------------------------


def _wrapv_d(kbpk: bytes, header_dump: str, key: bytes, extra_pad: int,
             padding_mode: str = "zero") -> dict[str, object]:
    img: dict[str, object] = {}
    cmac_r = _gen_work_keycmac_once(kbpk, VersionId.D)
