@dataclass
class WorkKeyResult:
    version_id: VersionId
    description: str
    kbek: bytes = b""
    kbak: bytes = b""
    error: str | None = None


@dataclass
class CmacSubkeyResult:
    algorithm: Algorithm
    k1: bytes | None = None
    k2: bytes | None = None
