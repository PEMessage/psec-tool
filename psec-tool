def _prompt(label: str, default: str, table: dict[str, str] | None = None) -> str:
    if table is None:
        value = input(f"{label} [{default}]: ").strip()
        return value if value else default

    values = list(table)
    for i, (value, description) in enumerate(table.items(), 1):
        print(f"  {i:>2}) {value:<2} - {description}")
    while True:
        value = input(f"{label} (value or number) [{default}]: ").strip()
        if not value:
            return default
        if value.isdigit() and 1 <= int(value) <= len(values):
            return values[int(value) - 1]
        if value in table:
            return value
        print(f"  error: '{value}' is not a valid choice")


def _mode_of_use_choices(key_usage: str) -> dict[str, str]:
    """Modes of use allowed for ``key_usage``.

    Falls back to the full table for unknown (e.g. proprietary numeric)
    key usage values.
    """
    if key_usage not in _KEY_USAGE_TABLE:
        return dict(_MODE_OF_USE_TABLE)
    valid_modes = _KEY_USAGE_TABLE[key_usage][1]
    return {
        value: description
        for value, description in _MODE_OF_USE_TABLE.items()
        if value in valid_modes
    }


def _gen_header_interactive(args: argparse.Namespace,
                            blocks: list[tuple[str, str]]) -> None:
    """Fill ``args`` fields by prompting. CLI values are the defaults."""
    print("-- version id --")
    args.version_id = _prompt("version id", args.version_id, _VERSION_ID_TABLE)
    print("-- key usage --")
    key_usage_table = {
        value: f"{description:<65} (mode of use: {'/'.join(modes)})"
        for value, (description, modes) in _KEY_USAGE_TABLE.items()
    }
    args.key_usage = _prompt("key usage", args.key_usage, key_usage_table)
    print("-- algorithm --")
    args.algorithm = _prompt("algorithm", args.algorithm, _ALGORITHM_TABLE)
    print("-- mode of use --")
    mode_of_use_table = _mode_of_use_choices(args.key_usage)
    if len(mode_of_use_table) != len(_MODE_OF_USE_TABLE):
        print(f"  (restricted by key usage {args.key_usage})")
    args.mode_of_use = _prompt("mode of use", args.mode_of_use, mode_of_use_table)
    print("-- version num --")
    print("  00 - key versioning is not used")
    print("  c? - the key block carries a component of a key")
    print("  ?? - any other value: version of the key")
    args.version_num = _prompt("version num", args.version_num)
    print("-- exportability --")
    args.exportability = _prompt("exportability", args.exportability, _EXPORTABILITY_TABLE)

    print("-- optional blocks --")
    while True:
        spec = input("optional block ID=DATA (empty to finish): ").strip()
        if not spec:
            break
        block_id, sep, block_data = spec.partition("=")
        if not sep:
            print("  invalid block spec, expected ID=DATA")
            continue
        blocks.append((block_id, block_data))

    print("-- key length --")
    key_len = input("key length in bytes (empty to skip): ").strip()
    args.key_len = int(key_len) if key_len else None
    print()


