def _key_usage_desc(ku: str) -> str:
    """Resolve key-usage description from the existing ``_KEY_USAGE_TABLE``."""
    entry = _KEY_USAGE_TABLE.get(ku)
    return entry[0] if entry is not None else "proprietary"


def _version_num_desc(vn: str) -> str:
    if vn == "00":
        return "No key versioning"
    elif vn[0] in ("c", "C"):
        return "Component of a key"
    else:
        return f"Key version '{vn}'"


def _print_header(header: "psec.tr31.Header") -> None:
    print(f"header: {header}")
    print(f"  version_id:    {header.version_id}  ({_VERSION_ID_TABLE.get(header.version_id, 'proprietary')})")
    print(f"  key_usage:     {header.key_usage}  ({_key_usage_desc(header.key_usage)})")
    print(f"  algorithm:     {header.algorithm}  ({_ALGORITHM_TABLE.get(header.algorithm, 'proprietary')})")
    print(f"  mode_of_use:   {header.mode_of_use}  ({_MODE_OF_USE_TABLE.get(header.mode_of_use, 'proprietary')})")
    print(f"  version_num:   {header.version_num}  ({_version_num_desc(header.version_num)})")
    print(f"  exportability: {header.exportability}  ({_EXPORTABILITY_TABLE.get(header.exportability, 'proprietary')})")
    print(f"  blocks:        {len(header.blocks)}")
    for block_id, block_data in header.blocks.items():
        print(f"    block[{block_id}]:   {block_data}")


@dataclass
class UnwrapResult:
    header: "psec.tr31.Header"
    key: bytes | None = None
    error: str | None = None


def do_tr31_unwrap(kbpk: bytes | None, key_block: str) -> UnwrapResult:
    if kbpk is None:
        header = psec.tr31.Header()
        header.load(key_block)
        return UnwrapResult(header=header)
    try:
        header, key = psec.tr31.unwrap(kbpk=kbpk, key_block=key_block)
    except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
        header = psec.tr31.Header()
        header.load(key_block)
        return UnwrapResult(header=header, error=str(e))
    return UnwrapResult(header=header, key=key)


def cmd_tr31_unwrap(args: argparse.Namespace) -> None:
    kbpk = bytes.fromhex(args.kbpk) if args.kbpk else None
    r = do_tr31_unwrap(kbpk, args.key_block)
    _print_header(r.header)
    if r.error is not None:
        print(f"error: {r.error}", file=sys.stderr)
        sys.exit(1)
    if r.key is not None:
        print(f"key: {r.key.hex().upper()}")


