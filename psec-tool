@dataclass
class GenHeaderResult:
    header: "psec.tr31.Header"
    header_str: str


def do_tr31_gen_header(
    version_id: str,
    key_usage: str,
    algorithm: str,
    mode_of_use: str,
    version_num: str,
    exportability: str,
    blocks: list[tuple[str, str]],
    key_len: int | None = None,
) -> GenHeaderResult:
    """Build a TR-31 header string.

    Field rules (validated by ``psec.tr31.Header``, all ASCII alphanumeric):
      version_id    : 1 char, one of A/B/C/D/E
                        A/C = TDES variant (deprecated),
                        B   = TDES key derivation (preferred TDES),
                        D   = AES key derivation,
                        E   = AES key derivation (ISO 20038)
      key_usage     : 2 chars (e.g. P0=PIN encryption, M3=MAC, K0=KEK, ...)
      algorithm     : 1 char (e.g. T=TDES, A=AES, D=DES, R=RSA, ...)
      mode_of_use   : 1 char (e.g. E=encrypt, D=decrypt, B=both, N=none, ...)
      version_num   : 2 chars (key version number, "00" = none)
      exportability : 1 char (e.g. E=exportable, N=non-exportable, S=sensitive)

    When ``key_len`` (bytes of the key to be wrapped) is given, the length
    field is the final key block length via ``Header.dump``; otherwise it is
    the bare header length (16 + optional blocks) via ``str(header)``.
    """
    header = psec.tr31.Header(
        version_id=version_id,
        key_usage=key_usage,
        algorithm=algorithm,
        mode_of_use=mode_of_use,
        version_num=version_num,
        exportability=exportability,
    )
    for block_id, block_data in blocks:
        header.blocks[block_id] = block_data
    header_str = header.dump(key_len) if key_len is not None else str(header)
    return GenHeaderResult(header=header, header_str=header_str)


def cmd_tr31_gen_header(args: argparse.Namespace) -> None:
    blocks: list[tuple[str, str]] = []
    for spec in args.block or []:
        block_id, sep, block_data = spec.partition("=")
        if not sep:
            print(f"error: invalid block spec '{spec}', expected ID=DATA", file=sys.stderr)
            sys.exit(1)
        blocks.append((block_id, block_data))

    if args.interactive:
        _gen_header_interactive(args, blocks)

    r = do_tr31_gen_header(
        version_id=args.version_id,
        key_usage=args.key_usage,
        algorithm=args.algorithm,
        mode_of_use=args.mode_of_use,
        version_num=args.version_num,
        exportability=args.exportability,
        blocks=blocks,
        key_len=args.key_len,
    )
    _print_header(r.header)
    print(r.header_str)


