#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.9"
# dependencies = [
#     "psec @ git+https://github.com/PEMessage/psec@1ec6663bccc27f26be707a48f292377c2ecc51f2",
#     "cryptography",
# ]
# ///
import argparse
import sys
import warnings
from dataclasses import dataclass

from cryptography.utils import CryptographyDeprecationWarning

warnings.filterwarnings("ignore", category=CryptographyDeprecationWarning)

import psec


def _print_header(header: "psec.tr31.Header") -> None:
    print(f"header: {header}")
    print(f"  version_id:    {header.version_id}")
    print(f"  key_usage:     {header.key_usage}")
    print(f"  algorithm:     {header.algorithm}")
    print(f"  mode_of_use:   {header.mode_of_use}")
    print(f"  version_num:   {header.version_num}")
    print(f"  exportability: {header.exportability}")
    print(f"  blocks:        {len(header.blocks)}")
    for block_id, block_data in header.blocks.items():
        print(f"    block[{block_id}]:   {block_data}")


@dataclass
class UnwrapResult:
    header: "psec.tr31.Header"
    key: bytes | None = None
    error: str | None = None


def do_tr31_unwrap(kbpk: bytes | None, key_block: str) -> UnwrapResult:
    if kbpk is None:
        header = psec.tr31.Header()
        header.load(key_block)
        return UnwrapResult(header=header)
    try:
        header, key = psec.tr31.unwrap(kbpk=kbpk, key_block=key_block)
    except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
        header = psec.tr31.Header()
        header.load(key_block)
        return UnwrapResult(header=header, error=str(e))
    return UnwrapResult(header=header, key=key)


def cmd_tr31_unwrap(args: argparse.Namespace) -> None:
    kbpk = bytes.fromhex(args.kbpk) if args.kbpk else None
    r = do_tr31_unwrap(kbpk, args.key_block)
    _print_header(r.header)
    if r.error is not None:
        print(f"error: {r.error}", file=sys.stderr)
        sys.exit(1)
    if r.key is not None:
        print(f"key: {r.key.hex().upper()}")


_KBPK_VERSIONS = [
    ("A", "TDES Key Variant Binding Method", "_c_derive"),
    ("B", "TDES Key Derivation Binding Method", "_b_derive"),
    ("C", "TDES Key Variant Binding Method", "_c_derive"),
    ("D", "AES Key Derivation Binding Method", "_d_derive"),
    ("E", "AES Key Derivation Binding Method", "_e_derive"),
]


@dataclass
class KbpkRow:
    version_id: str
    description: str
    kbek: str = ""
    kbak: str = ""
    error: str | None = None


def do_tr31_kbpk(kbpk: bytes) -> list[KbpkRow]:
    rows: list[KbpkRow] = []
    for version_id, description, method in _KBPK_VERSIONS:
        kb = psec.tr31.KeyBlock(
            kbpk=kbpk, header=psec.tr31.Header(version_id=version_id)
        )
        try:
            kbek, kbak = getattr(kb, method)()
        except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
            rows.append(KbpkRow(version_id, description, error=str(e)))
            continue
        rows.append(
            KbpkRow(version_id, description, kbek=kbek.hex().upper(), kbak=kbak.hex().upper())
        )
    return rows


def cmd_tr31_kbpk(args: argparse.Namespace) -> None:
    kbpk = bytes.fromhex(args.kbpk)
    print(f"kbpk: {kbpk.hex().upper()} ({len(kbpk)} bytes)")
    for r in do_tr31_kbpk(kbpk):
        print(f"version {r.version_id} ({r.description}):")
        if r.error is not None:
            print(f"  n/a: {r.error}")
        else:
            print(f"  kbek: {r.kbek}")
            print(f"  kbak: {r.kbak}")


@dataclass
class CmacSubkeyResult:
    algorithm: str
    k1: str | None = None
    k2: str | None = None
    error: str | None = None


def do_tr31_cmac_k1k2(key: bytes) -> list[CmacSubkeyResult]:
    # CMAC subkeys K1/K2 (NIST SP 800-38B). These are a low-level primitive:
    # K1/K2 = shift-left-1 of E_K(0), conditionally XOR'd with Rb
    # (Rb = ...1B for DES 8-byte blocks, ...87 for AES 16-byte blocks).
    #
    # These subkeys are NOT the KBEK/KBAK themselves; they are a building
    # block used *inside* the KBEK/KBAK derivation (see `tr31 kbpk`):
    #
    #   Version B (TDES) / D (AES) key derivation:
    #     1. Derive CMAC subkeys from the KBPK:
    #          DES: K1, _ = _derive_des_cmac_subkey(kbpk)   (uses K1)
    #          AES: _, K2 = _derive_aes_cmac_subkey(kbpk)   (uses K2)
    #     2. Build a derivation input block carrying:
    #          counter | usage (0000=enc / 0001=mac) | 00 | algo | key-bits
    #     3. XOR that input with the subkey (K1 for DES, K2 for AES) and
    #        run it through CBC-MAC under the KBPK (with IV=0, effectively
    #        ECB on a single block). Each pass yields 64 bits (DES) or 128
    #        bits (AES) of keying material.
    #     4. Concatenate passes (incrementing the counter) until enough bits:
    #          usage=0000 -> KBEK (encryption key)
    #          usage=0001 -> KBAK (authentication key)
    #     5. Truncate to the KBPK length.
    #
    #   Example (AES-128 version D, step by step):
    #     _, K2 = cmac-subkey-aes(KBPK)
    #     di = [01][0000][00][0002][0080][00...00]   # usage=enc, algo=AES-128
    #     KBEK = CBC-MAC(KBPK, di XOR K2)             # 1 pass = 16 bytes
    #     di[usage] = 0001
    #     KBAK = CBC-MAC(KBPK, di XOR K2)
    #
    #   The KBAK is then itself fed through the CMAC-subkey step again when
    #   generating the final key-block MAC (the last block is XOR'd with K1
    #   of the KBAK before the CBC-MAC pass).
    #
    #   Version A/C do NOT use CMAC subkeys at all; they derive KBEK/KBAK by
    #   XOR'ing the KBPK with the constants 0x45.. / 0x4D.. (variant method).
    kb = psec.tr31.KeyBlock(kbpk=b"\x00" * 16)
    results: list[CmacSubkeyResult] = []
    for algorithm, method in (
        ("DES", "_derive_des_cmac_subkey"),
        ("AES", "_derive_aes_cmac_subkey"),
    ):
        try:
            k1, k2 = getattr(kb, method)(key)
        except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
            results.append(CmacSubkeyResult(algorithm, error=str(e)))
            continue
        results.append(
            CmacSubkeyResult(algorithm, k1=k1.hex().upper(), k2=k2.hex().upper())
        )
    return results


def cmd_tr31_cmac_k1k2(args: argparse.Namespace) -> None:
    key = bytes.fromhex(args.key)
    print(f"key: {key.hex().upper()} ({len(key)} bytes)")
    for r in do_tr31_cmac_k1k2(key):
        print(f"{r.algorithm}:")
        if r.error is not None:
            print(f"  n/a: {r.error}")
        else:
            print(f"  k1: {r.k1}")
            print(f"  k2: {r.k2}")


@dataclass
class KbpkConfig:
    """One valid KBPK length for a given TR-31 version.

    Maps directly to the kd_input bytes used in CMAC-based key derivation:

        byte 0    : counter (1, 2, …)
        byte 1-2  : key usage indicator
        byte 3    : separator (always 0x00)
        byte 4-5  : algorithm indicator → ``algo``
        byte 6-7  : key length in bits    → ``keybits``
        bytes 8.. : zero-padding to reach the version's block_size
    """

    kbpk_bytes: int
    """KBPK key length in bytes (e.g. 16 for 2-key TDES or AES-128)."""

    description: str
    """Human-readable label (``"2-key"``, ``"AES-256"``, etc.)."""

    algo: str
    """Algorithm indicator, 2 hex chars (``"0000"`` = 2-key TDES,
    ``"0004"`` = AES-256, etc.)."""

    keybits: str
    """Key length in bits, 2 hex chars (``"0080"`` = 128 bits,
    ``"0100"`` = 256 bits, etc.)."""

    counters: list[int]
    """CMAC counter values (starting at 1).  The number of entries
    determines how many CBC-MAC passes are concatenated to produce
    keying material of the required length."""


@dataclass
class DeriveVersion:
    """TR-31 version entry for CMAC-based key derivation.

    Versions A/C are omitted — they use XOR-variant derivation
    and have no kd_input data blocks.
    """

    version_id: str
    """TR-31 version letter (``"B"``, ``"D"``, ``"E"``)."""

    cipher: str
    """Block cipher family (``"TDES"`` or ``"AES"``)."""

    block_size: int
    """Encryption block size in bytes (8 for TDES, 16 for AES)."""

    kbpk_configs: list[KbpkConfig]
    """Valid KBPK lengths and their kd_input parameters."""

    subkey: str
    """CMAC subkey used to mask the derivation input before CBC-MAC:
    ``"K1"`` for TDES (from ``_derive_des_cmac_subkey``),
    ``"K2"`` for AES  (from ``_derive_aes_cmac_subkey``)."""

    usage_enc: str
    """Usage indicator for the encryption KBEK, 2 hex chars:
    ``"0000"`` on versions B/D, ``"0002"`` (AES-CTR) on version E."""

    usage_mac: str
    """Usage indicator for the authentication KBAK, always ``"0001"``."""


# Derivation procedure for versions B / D / E:
#   1.  Derive CMAC subkey from KBPK: K1 (TDES) or K2 (AES).
#   2.  For each counter in ``counters``:
#       a. Set byte 0 = counter.
#       b. Set bytes 1-2 = usage (enc or mac).
#       c. XOR the full kd_input block with the subkey.
#       d. Run CBC-MAC (IV=0, effectively ECB on one block) under KBPK.
#       e. Each call yields 64 bits (TDES) or 128 bits (AES).
#   3.  Concatenate passes, truncate to KBPK length:
#         usage_enc → KBEK   usage_mac → KBAK
_DERIVE_DATA: list[DeriveVersion] = [
    DeriveVersion(
        version_id="B",
        cipher="TDES",
        block_size=8,
        subkey="K1",
        usage_enc="0000",
        usage_mac="0001",
        kbpk_configs=[
            KbpkConfig(kbpk_bytes=16, description="2-key", algo="0000", keybits="0080", counters=[1, 2]),
            KbpkConfig(kbpk_bytes=24, description="3-key", algo="0001", keybits="00C0", counters=[1, 2, 3]),
        ],
    ),
    DeriveVersion(
        version_id="D",
        cipher="AES",
        block_size=16,
        subkey="K2",
        usage_enc="0000",
        usage_mac="0001",
        kbpk_configs=[
            KbpkConfig(kbpk_bytes=16, description="AES-128", algo="0002", keybits="0080", counters=[1]),
            KbpkConfig(kbpk_bytes=24, description="AES-192", algo="0003", keybits="00C0", counters=[1, 2]),
            KbpkConfig(kbpk_bytes=32, description="AES-256", algo="0004", keybits="0100", counters=[1, 2]),
        ],
    ),
    DeriveVersion(
        version_id="E",
        cipher="AES",
        block_size=16,
        subkey="K2",
        usage_enc="0002",
        usage_mac="0001",
        kbpk_configs=[
            KbpkConfig(kbpk_bytes=16, description="AES-128", algo="0002", keybits="0080", counters=[1]),
            KbpkConfig(kbpk_bytes=24, description="AES-192", algo="0003", keybits="00C0", counters=[1, 2]),
            KbpkConfig(kbpk_bytes=32, description="AES-256", algo="0004", keybits="0100", counters=[1, 2]),
        ],
    ),
]


def _build_derive_data_block(
    block_size: int, counter: int, usage: str, algo: str, keybits: str
) -> str:
    b = bytearray(block_size)
    b[0] = counter
    b[1:3] = bytes.fromhex(usage)
    b[4:6] = bytes.fromhex(algo)
    b[6:8] = bytes.fromhex(keybits)
    return b.hex().upper()


@dataclass
class DeriveDataBlock:
    ver: DeriveVersion
    cfg: KbpkConfig
    counter: int
    usage: str
    data_hex: str


def do_tr31_derive_data() -> list[DeriveDataBlock]:
    rows: list[DeriveDataBlock] = []
    for v in _DERIVE_DATA:
        for cfg in v.kbpk_configs:
            for counter in cfg.counters:
                for usage_label, usage_hex in [("enc", v.usage_enc),
                                                ("mac", v.usage_mac)]:
                    data = _build_derive_data_block(
                        v.block_size, counter, usage_hex, cfg.algo, cfg.keybits
                    )
                    rows.append(
                        DeriveDataBlock(
                            ver=v,
                            cfg=cfg,
                            counter=counter,
                            usage=usage_label,
                            data_hex=data,
                        )
                    )
    return rows


def cmd_tr31_derive_data(args: argparse.Namespace) -> None:
    prev_cfg = None
    for r in do_tr31_derive_data():
        if r.cfg is not prev_cfg:
            print(
                f"version {r.ver.version_id} | cipher={r.ver.cipher} | "
                f"{r.cfg.description} | kbpk={r.cfg.kbpk_bytes}bytes | "
                f"subkey={r.ver.subkey} | calls={len(r.cfg.counters)}"
            )
            print(f"  block_size={r.ver.block_size}")
            print(f"    algo={r.cfg.algo}  keybits={r.cfg.keybits}")
        print(
            f"      counter={r.counter}  "
            f"usage_{r.usage}={r.ver.usage_enc if r.usage == 'enc' else r.ver.usage_mac}  "
            f"=> {r.data_hex}"
        )
        prev_cfg = r.cfg


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="psec-tool",
        description="CLI over the psec payment-security library.",
    )
    subcmds = parser.add_subparsers(dest="command", required=True)

    tr31 = subcmds.add_parser("tr31", help="TR-31 key block operations.")
    tr31_sub = tr31.add_subparsers(dest="tr31_command", required=True)

    unwrap = tr31_sub.add_parser("unwrap", help="Unwrap a key from a TR-31 key block.")
    unwrap.add_argument(
        "-k",
        "--kbpk",
        help="Key Block Protection Key as a hex string. "
        "If omitted, only the header is parsed (no decryption or MAC check).",
    )
    unwrap.add_argument(
        "key_block",
        help="TR-31 key block string to unwrap.",
    )
    unwrap.set_defaults(func=cmd_tr31_unwrap)

    kbpk = tr31_sub.add_parser(
        "kbpk",
        help="Print derived intermediate keys (KBEK/KBAK) for all versions.",
    )
    kbpk.add_argument(
        "-k",
        "--kbpk",
        required=True,
        help="Key Block Protection Key as a hex string.",
    )
    kbpk.set_defaults(func=cmd_tr31_kbpk)

    cmac_k1k2 = tr31_sub.add_parser(
        "cmac-k1k2",
        help="Derive CMAC subkeys K1/K2 from a key (building block of KBEK/KBAK).",
    )
    cmac_k1k2.add_argument(
        "key",
        help="Key as a hex string.",
    )
    cmac_k1k2.set_defaults(func=cmd_tr31_cmac_k1k2)

    derive_data = tr31_sub.add_parser(
        "derive-data",
        help="Print all derivation input data blocks for versions B/D/E.",
    )
    derive_data.set_defaults(func=cmd_tr31_derive_data)

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    try:
        args.func(args)
    except (ValueError, psec.tr31.KeyBlockError, psec.tr31.HeaderError) as e:
        print(f"error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()

