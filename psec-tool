import argparse
import sys
import warnings
from dataclasses import dataclass, field
from enum import Enum

from cryptography.utils import CryptographyDeprecationWarning

warnings.filterwarnings("ignore", category=CryptographyDeprecationWarning)

import psec


# ---------------------------------------------------------------------------
# unified version definitions
# ---------------------------------------------------------------------------

class VersionId(str, Enum):
    A = "A"
    B = "B"
    C = "C"
    D = "D"
    E = "E"

    def __str__(self) -> str:
        return self.value


@dataclass
class KbpkConfig:
    """One valid KBPK length and its kd_input parameters.

    Maps to bytes 4-7 of the CMAC derivation input block:

        byte 0    : counter (1, 2, …)
        byte 1-2  : key usage indicator
        byte 3    : separator (always 0x00)
        byte 4-5  : algorithm indicator → ``algo``
        byte 6-7  : key length in bits    → ``keybits``
        bytes 8.. : zero-padding to reach the version's block_size
    """

    kbpk_bytes: int
    """KBPK key length in bytes (e.g. 16 for 2-key TDES or AES-128)."""

    description: str
    """Human-readable label (``"2-key"``, ``"AES-256"``, etc.)."""

    algo: bytes
    """Algorithm indicator, 2 bytes (``b"\\x00\\x00"`` = 2-key TDES,
    ``b"\\x00\\x04"`` = AES-256, etc.)."""

    keybits: bytes
    """Key length in bits, 2 bytes (``b"\\x00\\x80"`` = 128 bits,
    ``b"\\x01\\x00"`` = 256 bits, etc.)."""

    counters: list[int]
    """CMAC counter values (starting at 1).  One pass per counter
    yields 64 bits (TDES) or 128 bits (AES) of keying material."""


@dataclass
class Tr31Version:
    """One TR-31 version — covers all five version IDs (A-E).

    Versions A/C use XOR-variant derivation (``method="xvariant"``).
    Versions B/D/E use CMAC-based derivation (``method="cmac"``).

    Derivation procedure for CMAC versions:
      1.  Derive CMAC subkey from KBPK: K1 (TDES) or K2 (AES).
      2.  For each counter in ``counters``:
          a. Set byte 0 = counter.
          b. Set bytes 1-2 = usage.
          c. XOR the full kd_input block with the subkey.
          d. Run CBC-MAC (IV=0 → ECB on one block) under KBPK.
          e. Each call yields 64 bits (TDES) or 128 bits (AES).
      3.  Concatenate passes, truncate to KBPK length:
            usage_enc → KBEK   usage_mac → KBAK
    """

    version_id: VersionId
    """TR-31 version letter (``"A"``-``"E"``)."""

    description: str
    """Full description (e.g. ``"TDES Key Derivation Binding Method"``)."""

    method: str
    """``"xvariant"`` or ``"cmac"``."""

    cipher: str = ""
    """Block cipher family (``"TDES"`` | ``"AES"``). Empty for xvariant."""

    block_size: int = 0
    """Encryption block size in bytes (8 | 16). 0 for xvariant."""

    subkey: str = ""
    """CMAC subkey used for masking (``"K1"`` | ``"K2"``). Empty for xvariant."""

    usage_enc: bytes = b""
    """Usage indicator for KBEK, 2 bytes (``b"\\x00\\x00"`` | ``b"\\x00\\x02"``)."""

    usage_mac: bytes = b""
    """Usage indicator for KBAK, 2 bytes (``b"\\x00\\x01"``)."""

    kbpk_configs: dict[int, KbpkConfig] = field(default_factory=dict)
    """Valid KBPK lengths (CMAC versions only). Keyed by ``kbpk_bytes``."""


_VERSIONS: dict[VersionId, Tr31Version] = {
    VersionId.A: Tr31Version(
        version_id=VersionId.A, description="TDES Key Variant Binding Method",
        method="xvariant",
    ),
    VersionId.B: Tr31Version(
        version_id=VersionId.B, description="TDES Key Derivation Binding Method",
        method="cmac",
        cipher="TDES", block_size=8, subkey="K1",
        usage_enc=bytes.fromhex("0000"), usage_mac=bytes.fromhex("0001"),
        kbpk_configs={
            16: KbpkConfig(16, "2-key", bytes.fromhex("0000"), bytes.fromhex("0080"), [1, 2]),
            24: KbpkConfig(24, "3-key", bytes.fromhex("0001"), bytes.fromhex("00C0"), [1, 2, 3]),
        },
    ),
    VersionId.C: Tr31Version(
        version_id=VersionId.C, description="TDES Key Variant Binding Method",
        method="xvariant",
    ),
    VersionId.D: Tr31Version(
        version_id=VersionId.D, description="AES Key Derivation Binding Method",
        method="cmac",
        cipher="AES", block_size=16, subkey="K2",
        usage_enc=bytes.fromhex("0000"), usage_mac=bytes.fromhex("0001"),
        kbpk_configs={
            16: KbpkConfig(16, "AES-128", bytes.fromhex("0002"), bytes.fromhex("0080"), [1]),
            24: KbpkConfig(24, "AES-192", bytes.fromhex("0003"), bytes.fromhex("00C0"), [1, 2]),
            32: KbpkConfig(32, "AES-256", bytes.fromhex("0004"), bytes.fromhex("0100"), [1, 2]),
        },
    ),
    VersionId.E: Tr31Version(
        version_id=VersionId.E, description="AES Key Derivation Binding Method",
        method="cmac",
        cipher="AES", block_size=16, subkey="K2",
        usage_enc=bytes.fromhex("0002"), usage_mac=bytes.fromhex("0001"),
        kbpk_configs={
            16: KbpkConfig(16, "AES-128", bytes.fromhex("0002"), bytes.fromhex("0080"), [1]),
            24: KbpkConfig(24, "AES-192", bytes.fromhex("0003"), bytes.fromhex("00C0"), [1, 2]),
            32: KbpkConfig(32, "AES-256", bytes.fromhex("0004"), bytes.fromhex("0100"), [1, 2]),
        },
    ),
}


@dataclass(frozen=True)
class VersionCfg:
    """Canonical key into ``_VERSIONS`` / ``kbpk_configs``."""
    version_id: VersionId
    kbpk_bytes: int


@dataclass
class DeriveData:
    """All derivation blocks for one ``VersionCfg``."""
    vc: VersionCfg
    blocks: dict[str, list[bytes]]  # "enc" | "mac" -> data per counter


def _lookup(vc: VersionCfg) -> tuple[Tr31Version, KbpkConfig]:
    """Resolve a ``VersionCfg`` to its full objects."""
    v = _VERSIONS[vc.version_id]
    return v, v.kbpk_configs[vc.kbpk_bytes]


# ---------------------------------------------------------------------------
# helper
# ---------------------------------------------------------------------------

def _build_derive_data_block(
    block_size: int, counter: int, usage: bytes, algo: bytes, keybits: bytes,
) -> bytes:
    data = bytes([counter]) + usage + b"\x00" + algo + keybits
    # ISO 9797-1 method 2: append 0x80 then zero-fill to block_size
    pad = block_size - (len(data) % block_size)
    if pad != block_size:
        data += b"\x80" + b"\x00" * (pad - 1)
    return data


# ---------------------------------------------------------------------------
# shared result types
# ---------------------------------------------------------------------------

@dataclass
class KbpkRow:
    version_id: VersionId
    description: str
    kbek: bytes = b""
    kbak: bytes = b""
    error: str | None = None


@dataclass
class CmacSubkeyResult:
    algorithm: str
    k1: bytes | None = None
    k2: bytes | None = None
    error: str | None = None


# ---------------------------------------------------------------------------
# unwrap
# ---------------------------------------------------------------------------

def _print_header(header: "psec.tr31.Header") -> None:
    print(f"header: {header}")
    print(f"  version_id:    {header.version_id}")
    print(f"  key_usage:     {header.key_usage}")
    print(f"  algorithm:     {header.algorithm}")
    print(f"  mode_of_use:   {header.mode_of_use}")
    print(f"  version_num:   {header.version_num}")
    print(f"  exportability: {header.exportability}")
    print(f"  blocks:        {len(header.blocks)}")
    for block_id, block_data in header.blocks.items():
        print(f"    block[{block_id}]:   {block_data}")


@dataclass
class UnwrapResult:
    header: "psec.tr31.Header"
    key: bytes | None = None
    error: str | None = None


def do_tr31_unwrap(kbpk: bytes | None, key_block: str) -> UnwrapResult:
    if kbpk is None:
        header = psec.tr31.Header()
        header.load(key_block)
        return UnwrapResult(header=header)
    try:
        header, key = psec.tr31.unwrap(kbpk=kbpk, key_block=key_block)
    except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
        header = psec.tr31.Header()
        header.load(key_block)
        return UnwrapResult(header=header, error=str(e))
    return UnwrapResult(header=header, key=key)


def cmd_tr31_unwrap(args: argparse.Namespace) -> None:
    kbpk = bytes.fromhex(args.kbpk) if args.kbpk else None
    r = do_tr31_unwrap(kbpk, args.key_block)
    _print_header(r.header)
    if r.error is not None:
        print(f"error: {r.error}", file=sys.stderr)
        sys.exit(1)
    if r.key is not None:
        print(f"key: {r.key.hex().upper()}")


# ---------------------------------------------------------------------------
# kbpk  (library KBEK / KBAK)
# ---------------------------------------------------------------------------

def do_tr31_kbpk(kbpk: bytes) -> dict[VersionId, KbpkRow]:
    _method = {
        VersionId.B: "_b_derive", VersionId.D: "_d_derive", VersionId.E: "_e_derive",
        VersionId.A: "_c_derive", VersionId.C: "_c_derive",
    }
    rows: dict[VersionId, KbpkRow] = {}
    for v in _VERSIONS.values():
        kb = psec.tr31.KeyBlock(
            kbpk=kbpk, header=psec.tr31.Header(version_id=v.version_id)
        )
        try:
            kbek, kbak = getattr(kb, _method[v.version_id])()
            rows[v.version_id] = KbpkRow(
                v.version_id, v.description,
                kbek=kbek, kbak=kbak,
            )
        except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
            rows[v.version_id] = KbpkRow(v.version_id, v.description, error=str(e))
    return rows


def cmd_tr31_kbpk(args: argparse.Namespace) -> None:
    kbpk = bytes.fromhex(args.kbpk)
    print(f"kbpk: {kbpk.hex().upper()} ({len(kbpk)} bytes)")
    for r in do_tr31_kbpk(kbpk).values():
        print(f"version {r.version_id} ({r.description}):")
        if r.error is not None:
            print(f"  n/a: {r.error}")
        else:
            print(f"  kbek: {r.kbek.hex().upper()}")
            print(f"  kbak: {r.kbak.hex().upper()}")


# ---------------------------------------------------------------------------
# cmac-k1k2
# ---------------------------------------------------------------------------

def do_tr31_cmac_k1k2(key: bytes) -> dict[str, CmacSubkeyResult]:
    # CMAC subkeys K1/K2 (NIST SP 800-38B). These are a low-level primitive:
    # K1/K2 = shift-left-1 of E_K(0), conditionally XOR'd with Rb
    # (Rb = ...1B for DES 8-byte blocks, ...87 for AES 16-byte blocks).
    #
    # These subkeys are NOT the KBEK/KBAK themselves; they are a building
    # block used *inside* the KBEK/KBAK derivation (see `tr31 kbpk`):
    #
    #   Version B (TDES) / D / E (AES) key derivation:
    #     1. Derive CMAC subkeys from the KBPK:
    #          DES: K1, _ = _derive_des_cmac_subkey(kbpk)   (uses K1)
    #          AES: _, K2 = _derive_aes_cmac_subkey(kbpk)   (uses K2)
    #     2. Build a derivation input block carrying:
    #          counter | usage (enc/mac) | 00 | algo | key-bits | pad
    #     3. XOR that input with the subkey (K1 for DES, K2 for AES) and
    #        run it through CBC-MAC under KBPK (IV=0 → ECB on one block).
    #        Each pass yields 64 bits (DES) or 128 bits (AES) of key material.
    #     4. Concatenate passes (incrementing counter) until enough bits:
    #          usage_enc → KBEK   usage_mac → KBAK
    #     5. Truncate to KBPK length.
    #
    #   The KBAK is then itself fed through the CMAC-subkey step again when
    #   generating the final key-block MAC (the last MAC-data block is XOR'd
    #   with K1 of the KBAK before the CBC-MAC pass).
    #
    #   Version A/C do NOT use CMAC subkeys at all; they derive KBEK/KBAK by
    #   XOR'ing the KBPK with the constants 0x45.. / 0x4D.. (variant method).
    kb = psec.tr31.KeyBlock(kbpk=b"\x00" * 16)
    results: dict[str, CmacSubkeyResult] = {}
    for algorithm, method in (
        ("DES", "_derive_des_cmac_subkey"),
        ("AES", "_derive_aes_cmac_subkey"),
    ):
        try:
            k1, k2 = getattr(kb, method)(key)
        except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
            results[algorithm] = CmacSubkeyResult(algorithm, error=str(e))
            continue
        results[algorithm] = CmacSubkeyResult(algorithm, k1=k1, k2=k2)
    return results


def cmd_tr31_cmac_k1k2(args: argparse.Namespace) -> None:
    key = bytes.fromhex(args.key)
    print(f"key: {key.hex().upper()} ({len(key)} bytes)")
    for algorithm, r in do_tr31_cmac_k1k2(key).items():
        print(f"{algorithm}:")
        if r.error is not None:
            print(f"  n/a: {r.error}")
        else:
            print(f"  k1: {r.k1.hex().upper()}")
            print(f"  k2: {r.k2.hex().upper()}")


# ---------------------------------------------------------------------------
# derive-data
# ---------------------------------------------------------------------------

def do_tr31_derive_data() -> list[DeriveData]:
    result: list[DeriveData] = []
    for version_id, v in _VERSIONS.items():
        if v.method != "cmac":
            continue
        for kbpk_bytes, cfg in v.kbpk_configs.items():
            blocks: dict[str, list[bytes]] = {"enc": [], "mac": []}
            for counter in cfg.counters:
                for usage_label, usage in [("enc", v.usage_enc),
                                           ("mac", v.usage_mac)]:
                    data = _build_derive_data_block(
                        v.block_size, counter, usage, cfg.algo, cfg.keybits,
                    )
                    blocks[usage_label].append(data)
            result.append(DeriveData(
                vc=VersionCfg(version_id, kbpk_bytes), blocks=blocks,
            ))
    return result


def cmd_tr31_derive_data(args: argparse.Namespace) -> None:
    for d in do_tr31_derive_data():
        v, cfg = _lookup(d.vc)
        print(
            f"version {v.version_id} | cipher={v.cipher} | "
            f"{cfg.description} | kbpk={cfg.kbpk_bytes}bytes | "
            f"subkey={v.subkey} | calls={len(cfg.counters)}"
        )
        print(f"  block_size={v.block_size}")
        print(f"    algo={cfg.algo.hex().upper()}  keybits={cfg.keybits.hex().upper()}")
        for i, counter in enumerate(cfg.counters):
            enc_data = d.blocks["enc"][i]
            mac_data = d.blocks["mac"][i]
            print(
                f"      counter={counter}  "
                f"usage_enc=({v.usage_enc.hex().upper()}): "
                f"=> {enc_data.hex().upper()}"
            )
            print(
                f"      counter={counter}  "
                f"usage_mac=({v.usage_mac.hex().upper()}): "
                f"=> {mac_data.hex().upper()}"
            )


# ---------------------------------------------------------------------------
# manual KBEK/KBAK derivation (composed from cmac-k1k2 + derive-data)
# ---------------------------------------------------------------------------

def _derive_bde_pass(
    kbpk: bytes, cipher: str, data_bytes: bytes, block_size: int, subkey: bytes,
) -> bytes:
    from psec import mac as _psec_mac, tools as _psec_tools

    xor_data = _psec_tools.xor(data_bytes, subkey)

    algorithm = psec.mac.Algorithm.DES if cipher == "TDES" else psec.mac.Algorithm.AES
    return _psec_mac.generate_cbc_mac(
        kbpk, xor_data, 1, block_size, algorithm,
    )


@dataclass
class ConDeriveTrace(KbpkRow):
    subkey_name: str = ""
    subkey: bytes = b""
    passes: list[tuple[int, str, bytes, bytes]] = field(default_factory=list)
    # (counter, usage_label, xor, pass_result) per CBC-MAC pass


def do_tr31_kbek_kbak_ver_derive(kbpk: bytes) -> dict[VersionId, ConDeriveTrace]:
    data_by_vid = {d.vc.version_id: d for d in do_tr31_derive_data()
                   if d.vc.kbpk_bytes == len(kbpk)}
    cmac_subkeys = do_tr31_cmac_k1k2(kbpk)

    acc: dict[VersionId, ConDeriveTrace] = {}
    for version_id, d in data_by_vid.items():
        v, cfg = _lookup(d.vc)
        algo = "DES" if v.cipher == "TDES" else v.cipher
        subkey = cmac_subkeys[algo].k1 if v.subkey == "K1" else cmac_subkeys[algo].k2
        acc[version_id] = ConDeriveTrace(
            version_id=v.version_id,
            description=cfg.description,
            subkey_name=v.subkey,
            subkey=subkey,
        )
        for i, counter in enumerate(cfg.counters):
            for usage_label in ("enc", "mac"):
                data = d.blocks[usage_label][i]
                pass_bytes = _derive_bde_pass(kbpk, v.cipher, data, v.block_size, subkey)
                xor_bytes = psec.tools.xor(data, subkey)
                acc[version_id].passes.append((counter, usage_label, xor_bytes, pass_bytes))
                if usage_label == "enc":
                    acc[version_id].kbek += pass_bytes
                else:
                    acc[version_id].kbak += pass_bytes

    for t in acc.values():
        t.kbek = t.kbek[:len(kbpk)]
        t.kbak = t.kbak[:len(kbpk)]
    return acc


def do_tr31_kbek_kbak_ver_xvariant(kbpk: bytes) -> dict[VersionId, KbpkRow]:
    rows: dict[VersionId, KbpkRow] = {}
    for v in _VERSIONS.values():
        if v.method != "xvariant":
            continue
        bek = psec.tools.xor(kbpk, b"\x45" * len(kbpk))
        bak = psec.tools.xor(kbpk, b"\x4D" * len(kbpk))
        rows[v.version_id] = KbpkRow(
            v.version_id, v.description,
            kbek=bek, kbak=bak,
        )
    return rows


# ---------------------------------------------------------------------------
# kbek-kbak  (compare manual derivation with library)
# ---------------------------------------------------------------------------

def cmd_tr31_kbek_kbak(args: argparse.Namespace) -> None:
    kbpk = bytes.fromhex(args.kbpk)
    print(f"kbpk: {kbpk.hex().upper()} ({len(kbpk)} bytes)\n")

    lib_by_ver = do_tr31_kbpk(kbpk)
    manual_derive = do_tr31_kbek_kbak_ver_derive(kbpk)
    manual_xvariant = do_tr31_kbek_kbak_ver_xvariant(kbpk)

    for version_id, t in manual_derive.items():
        print(f"version {t.version_id} | {t.description}:")
        print(f"  {t.subkey_name} -> {t.subkey.hex().upper()}")
        for counter, usage, xor_bytes, pass_bytes in t.passes:
            print(f"  kd[{counter}]{usage}: {xor_bytes.hex().upper()}  --CBC-MAC--> {pass_bytes.hex().upper()}")
        print(f"  => kbek: {t.kbek.hex().upper()}")
        print(f"  => kbak: {t.kbak.hex().upper()}")

        l = lib_by_ver[version_id]
        if l.error is None:
            ok_bek = "(OK)" if t.kbek == l.kbek else "(MISMATCH)"
            ok_bak = "(OK)" if t.kbak == l.kbak else "(MISMATCH)"
            print(f"     lib kbek: {l.kbek.hex().upper()}  {ok_bek}")
            print(f"     lib kbak: {l.kbak.hex().upper()}  {ok_bak}")
        else:
            print("     lib: n/a")
        print()

    for version_id, r in manual_xvariant.items():
        l = lib_by_ver[version_id]
        if l.error is not None:
            continue
        print(f"version {r.version_id} | XOR variant:")
        ok_bek = "(OK)" if r.kbek == l.kbek else "(MISMATCH)"
        ok_bak = "(OK)" if r.kbak == l.kbak else "(MISMATCH)"
        print(f"  => kbek: {r.kbek.hex().upper()}  {ok_bek}  (kbpk ^ 0x45..45)")
        print(f"  => kbak: {r.kbak.hex().upper()}  {ok_bak}  (kbpk ^ 0x4D..4D)\n")


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="psec-tool",
        description="CLI over the psec payment-security library.",
    )
    subcmds = parser.add_subparsers(dest="command", required=True)

    tr31 = subcmds.add_parser("tr31", help="TR-31 key block operations.")
    tr31_sub = tr31.add_subparsers(dest="tr31_command", required=True)

    unwrap = tr31_sub.add_parser("unwrap", help="Unwrap a key from a TR-31 key block.")
    unwrap.add_argument(
        "-k", "--kbpk",
        help="Key Block Protection Key as a hex string. "
        "If omitted, only the header is parsed (no decryption or MAC check).",
    )
    unwrap.add_argument("key_block", help="TR-31 key block string to unwrap.")
    unwrap.set_defaults(func=cmd_tr31_unwrap)

    kbpk = tr31_sub.add_parser("kbpk", help="Derive KBEK/KBAK for all versions (via library).")
    kbpk.add_argument("-k", "--kbpk", required=True, help="Key Block Protection Key as a hex string.")
    kbpk.set_defaults(func=cmd_tr31_kbpk)

    cmac_k1k2 = tr31_sub.add_parser("cmac-k1k2", help="Derive CMAC subkeys K1/K2.")
    cmac_k1k2.add_argument("key", help="Key as a hex string.")
    cmac_k1k2.set_defaults(func=cmd_tr31_cmac_k1k2)

    derive_data = tr31_sub.add_parser("derive-data", help="Derivation input data blocks for CMAC versions.")
    derive_data.set_defaults(func=cmd_tr31_derive_data)

    kbek_kbak = tr31_sub.add_parser("kbek-kbak", help="Manual KBEK/KBAK derivation with library comparison.")
    kbek_kbak.add_argument("-k", "--kbpk", required=True, help="Key Block Protection Key as a hex string.")
    kbek_kbak.set_defaults(func=cmd_tr31_kbek_kbak)

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    try:
        args.func(args)
    except (ValueError, psec.tr31.KeyBlockError, psec.tr31.HeaderError) as e:
        print(f"error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()

