@dataclass
class WrapResult:
    key_block: str = ""
    error: str | None = None


def do_tr31_wrap(kbpk: bytes, header: str, key: bytes,
                 masked_key_len: int | None = None) -> WrapResult:
    try:
        kb = psec.tr31.wrap(kbpk=kbpk, header=header, key=key,
                            masked_key_len=masked_key_len)
        return WrapResult(key_block=kb)
    except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
        return WrapResult(error=str(e))


def cmd_tr31_wrap(args: argparse.Namespace) -> None:
    kbpk = bytes.fromhex(args.kbpk)
    key = bytes.fromhex(args.key)
    r = do_tr31_wrap(kbpk, args.header, key, args.masked_key_len)
    if r.error is not None:
        print(f"error: {r.error}", file=sys.stderr)
        sys.exit(1)
    print(r.key_block)


