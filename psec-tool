    img["method"] = "cmac"
    img["algorithm"] = Algorithm.AES
    img["subkey_name"] = cmac_r.subkey_name
    img["subkey"] = cmac_r.subkey
    img["kbek"] = kbek
    img["kbak"] = kbak
    img["cmac_passes"] = cmac_r.passes

    clear_key_data, pad_len, total_pad, key_len_bits, padding = _wrapv_clear_key(
        key, extra_pad, 16, padding_mode,
    )
    img["key_len_bits"] = key_len_bits
    img["pad_len"] = pad_len
    img["total_pad"] = total_pad
    img["clear_key_data"] = clear_key_data

    k1, _ = psec.tr31.KeyBlock(kbpk=b"\x00" * 16)._derive_aes_cmac_subkey(kbak)
    mac_data_full = header_dump.encode("ascii") + clear_key_data
    mac_data_xor = mac_data_full[:-16] + psec.tools.xor(mac_data_full[-16:], k1)
    mac = psec.mac.generate_cbc_mac(kbak, mac_data_xor, 1, 16, psec.mac.Algorithm.AES)
    img["mac_k1"] = k1
    img["mac_data_full"] = mac_data_full
    img["mac_data_xor"] = mac_data_xor
    img["mac"] = mac

    enc_key = psec.aes.encrypt_aes_cbc(kbek, mac, clear_key_data)
    img["iv_mac"] = mac
    img["enc_key"] = enc_key

    img["key_block"] = header_dump + enc_key.hex().upper() + mac.hex().upper()
    return img


# ---------------------------------------------------------------------------
# Version E: AES CMAC derivation + AES-CTR (MAC as nonce)
# ---------------------------------------------------------------------------


def _wrapv_e(kbpk: bytes, header_dump: str, key: bytes, extra_pad: int,
             padding_mode: str = "zero") -> dict[str, object]:
    img: dict[str, object] = {}
    cmac_r = _gen_work_keycmac_once(kbpk, VersionId.E)
    kbek, kbak = cmac_r.kbek, cmac_r.kbak
    img["method"] = "cmac"
    img["algorithm"] = Algorithm.AES
    img["subkey_name"] = cmac_r.subkey_name
    img["subkey"] = cmac_r.subkey
    img["kbek"] = kbek
    img["kbak"] = kbak
    img["cmac_passes"] = cmac_r.passes

    clear_key_data, pad_len, total_pad, key_len_bits, padding = _wrapv_clear_key(
        key, extra_pad, 0, padding_mode,
    )
    img["key_len_bits"] = key_len_bits
    img["pad_len"] = pad_len
    img["total_pad"] = total_pad
    img["clear_key_data"] = clear_key_data

    k1, k2 = psec.tr31.KeyBlock(kbpk=b"\x00" * 16)._derive_aes_cmac_subkey(kbak)
    mac_data_full = header_dump.encode("ascii") + clear_key_data
    if len(mac_data_full) % 16 == 0:
        mac_data_xor = mac_data_full[:-16] + psec.tools.xor(mac_data_full[-16:], k1)
        img["mac_padded"] = False
    else:
        padded = psec.mac.pad_iso_2(mac_data_full, 16)
        mac_data_xor = padded[:-16] + psec.tools.xor(padded[-16:], k2)
        img["mac_padded"] = True
    mac = psec.mac.generate_cbc_mac(kbak, mac_data_xor, 1, 16, psec.mac.Algorithm.AES)
    img["mac_k1"] = k1
    img["mac_k2"] = k2
    img["mac_data_full"] = mac_data_full
    img["mac_data_xor"] = mac_data_xor
    img["mac"] = mac

    enc_key = psec.aes.encrypt_aes_ctr(kbek, mac, clear_key_data)
    img["nonce"] = mac
    img["enc_key"] = enc_key

    img["key_block"] = header_dump + enc_key.hex().upper() + mac.hex().upper()
    return img


