# ---------------------------------------------------------------------------
# unwrap
# ---------------------------------------------------------------------------

def _print_header(header: "psec.tr31.Header") -> None:
    print(f"header: {header}")
    print(f"  version_id:    {header.version_id}")
    print(f"  key_usage:     {header.key_usage}")
    print(f"  algorithm:     {header.algorithm}")
    print(f"  mode_of_use:   {header.mode_of_use}")
    print(f"  version_num:   {header.version_num}")
    print(f"  exportability: {header.exportability}")
    print(f"  blocks:        {len(header.blocks)}")
    for block_id, block_data in header.blocks.items():
        print(f"    block[{block_id}]:   {block_data}")


@dataclass
class UnwrapResult:
    header: "psec.tr31.Header"
    key: bytes | None = None
    error: str | None = None


def do_tr31_unwrap(kbpk: bytes | None, key_block: str) -> UnwrapResult:
    if kbpk is None:
        header = psec.tr31.Header()
        header.load(key_block)
        return UnwrapResult(header=header)
    try:
        header, key = psec.tr31.unwrap(kbpk=kbpk, key_block=key_block)
    except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
        header = psec.tr31.Header()
        header.load(key_block)
        return UnwrapResult(header=header, error=str(e))
    return UnwrapResult(header=header, key=key)


def cmd_tr31_unwrap(args: argparse.Namespace) -> None:
    kbpk = bytes.fromhex(args.kbpk) if args.kbpk else None
    r = do_tr31_unwrap(kbpk, args.key_block)
    _print_header(r.header)
    if r.error is not None:
        print(f"error: {r.error}", file=sys.stderr)
        sys.exit(1)
    if r.key is not None:
        print(f"key: {r.key.hex().upper()}")


# ---------------------------------------------------------------------------
# wrap
# ---------------------------------------------------------------------------

@dataclass
class WrapResult:
    key_block: str = ""
    error: str | None = None


def do_tr31_wrap(kbpk: bytes, header: str, key: bytes,
                 masked_key_len: int | None = None) -> WrapResult:
    try:
        kb = psec.tr31.wrap(kbpk=kbpk, header=header, key=key,
                            masked_key_len=masked_key_len)
        return WrapResult(key_block=kb)
    except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
        return WrapResult(error=str(e))


def cmd_tr31_wrap(args: argparse.Namespace) -> None:
    kbpk = bytes.fromhex(args.kbpk)
    key = bytes.fromhex(args.key)
    r = do_tr31_wrap(kbpk, args.header, key, args.masked_key_len)
    if r.error is not None:
        print(f"error: {r.error}", file=sys.stderr)
        sys.exit(1)
    print(r.key_block)


# ---------------------------------------------------------------------------
# kbpk  (library KBEK / KBAK)
# ---------------------------------------------------------------------------

def _gen_work_keylib_once(kbpk: bytes, version_id: VersionId) -> tuple[bytes, bytes]:
    """Derive KBEK/KBAK for a single version via the psec library."""
    _method = {
        VersionId.A: "_c_derive", VersionId.B: "_b_derive",
        VersionId.C: "_c_derive", VersionId.D: "_d_derive",
        VersionId.E: "_e_derive",
    }
    kb = psec.tr31.KeyBlock(
        kbpk=kbpk, header=psec.tr31.Header(version_id=version_id),
    )
    return getattr(kb, _method[version_id])()


def do_tr31_gen_work_key_lib(kbpk: bytes) -> dict[VersionId, WorkKeyResult]:
    rows: dict[VersionId, WorkKeyResult] = {}
    for v in _VERSIONS.values():
        try:
            kbek, kbak = _gen_work_keylib_once(kbpk, v.version_id)
            rows[v.version_id] = WorkKeyResult(
                v.version_id, v.description,
                kbek=kbek, kbak=kbak,
            )
        except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
            rows[v.version_id] = WorkKeyResult(v.version_id, v.description, error=str(e))
    return rows


def cmd_tr31_kbpk(args: argparse.Namespace) -> None:
    kbpk = bytes.fromhex(args.kbpk)
    print(f"kbpk: {kbpk.hex().upper()} ({len(kbpk)} bytes)")
    for r in do_tr31_gen_work_key_lib(kbpk).values():
        print(f"version {r.version_id} ({r.description}):")
        if r.error is not None:
            print(f"  n/a: {r.error}")
        else:
            print(f"  kbek: {r.kbek.hex().upper()}")
            print(f"  kbak: {r.kbak.hex().upper()}")


# ---------------------------------------------------------------------------
# cmac-k1k2
# ---------------------------------------------------------------------------

def _derive_cmac_subkey_once(key: bytes, cipher: Algorithm) -> tuple[bytes, bytes]:
    """Derive CMAC subkeys K1, K2 for a single cipher algorithm.

    Parameters
    ----------
    key : bytes
        The key to derive CMAC subkeys from.
    cipher : Algorithm
        ``Algorithm.TDES`` or ``Algorithm.AES``.

    Returns
    -------
    k1, k2 : tuple[bytes, bytes]
    """
    method = "_derive_des_cmac_subkey" if cipher is Algorithm.TDES else "_derive_aes_cmac_subkey"
    kb = psec.tr31.KeyBlock(kbpk=b"\x00" * 16)
    return getattr(kb, method)(key)


# CMAC subkeys K1/K2 (NIST SP 800-38B). These are a low-level primitive:
# K1/K2 = shift-left-1 of E_K(0), conditionally XOR'd with Rb
# (Rb = ...1B for DES 8-byte blocks, ...87 for AES 16-byte blocks).
#
# These subkeys are NOT the KBEK/KBAK themselves; they are a building
# block used *inside* the KBEK/KBAK derivation (see `tr31 kbpk`):
#
#   Version B (TDES) / D / E (AES) key derivation:
#     1. Derive CMAC subkeys from the KBPK:
#          DES: K1, _ = _derive_des_cmac_subkey(kbpk)   (uses K1)
#          AES: _, K2 = _derive_aes_cmac_subkey(kbpk)   (uses K2)
#     2. Build a derivation input block carrying:
#          counter | usage (enc/mac) | 00 | algo | key-bits | pad
#     3. XOR that input with the subkey (K1 for DES, K2 for AES) and
#        run it through CBC-MAC under KBPK (IV=0 → ECB on one block).
#        Each pass yields 64 bits (DES) or 128 bits (AES) of key material.
#     4. Concatenate passes (incrementing counter) until enough bits:
#          usage_enc → KBEK   usage_mac → KBAK
#     5. Truncate to KBPK length.
#
#   The KBAK is then itself fed through the CMAC-subkey step again when
#   generating the final key-block MAC (the last MAC-data block is XOR'd
#   with K1 of the KBAK before the CBC-MAC pass).
#
#   Version A/C do NOT use CMAC subkeys at all; they derive KBEK/KBAK by
#   XOR'ing the KBPK with the constants 0x45.. / 0x4D.. (variant method).

def do_tr31_cmac_k1k2(key: bytes) -> dict[Algorithm, CmacSubkeyResult]:
    results: dict[Algorithm, CmacSubkeyResult] = {}
    for algo in Algorithm:
        try:
            k1, k2 = _derive_cmac_subkey_once(key, algo)
        except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
            results[algo] = CmacSubkeyResult(algo, error=str(e))
            continue
        results[algo] = CmacSubkeyResult(algo, k1=k1, k2=k2)
    return results


def cmd_tr31_cmac_k1k2(args: argparse.Namespace) -> None:
    key = bytes.fromhex(args.key)
    print(f"key: {key.hex().upper()} ({len(key)} bytes)")
    for algo, r in do_tr31_cmac_k1k2(key).items():
        print(f"{algo}:")
        if r.error is not None:
            print(f"  n/a: {r.error}")
        else:
            print(f"  k1: {r.k1.hex().upper()}")
            print(f"  k2: {r.k2.hex().upper()}")


# ---------------------------------------------------------------------------
# cmac
# ---------------------------------------------------------------------------

def _cmac_once(key: bytes, data: bytes, cipher: Algorithm) -> bytes:
    """Compute CMAC (NIST SP 800-38B) tag over ``data``.

    Parameters
    ----------
    key : bytes
        The CMAC key.
    data : bytes
        Data to authenticate.
    cipher : Algorithm
        ``Algorithm.TDES`` or ``Algorithm.AES``.

    Returns
    -------
    mac : bytes
        CMAC tag (8 bytes for TDES, 16 bytes for AES).
    """
    block_size = cipher.block_size
    k1, k2 = _derive_cmac_subkey_once(key, cipher)

    remainder = len(data) % block_size
    if remainder != 0 or len(data) == 0:
        data = psec.mac.pad_iso_2(data, block_size)
        last_subkey = k2
    else:
        last_subkey = k1

    data = data[:-block_size] + psec.tools.xor(data[-block_size:], last_subkey)
    return psec.mac.generate_cbc_mac(key, data, 1, block_size, cipher.mac_algorithm)


def cmd_tr31_cmac(args: argparse.Namespace) -> None:
    key = bytes.fromhex(args.key)
    data = bytes.fromhex(args.data)
    mac = _cmac_once(key, data, Algorithm(args.algo))
    print(mac.hex().upper())


# ---------------------------------------------------------------------------
# derive-data
# ---------------------------------------------------------------------------

@dataclass
class DeriveBlock:
    """One derivation input block (one counter × usage pair)."""
    counter: int
    usage_label: str         # "enc" or "mac"
    raw: bytes               # unpadded derivation input
    padded: bytes            # ISO-9797-1 method-2 padded block (or raw if none needed)
    has_padding: bool        # True when ISO padding was applied


@dataclass
class DeriveData:
    """All derivation blocks for one ``VersionCfg``."""
    vc: VersionCfg
    blocks: dict[str, list[DeriveBlock]]  # "enc" | "mac" -> list of DeriveBlock


def _derive_data_blocks_once(vc: VersionCfg) -> dict[str, list[DeriveBlock]]:
    """Derive input data blocks for a single ``VersionCfg``.

    Returns ``{"enc": [...], "mac": [...]}`` — one ``DeriveBlock`` per
    counter/usage pair, carrying both the raw (unpadded) derivation
    input and the ISO-9797-1 method-2 padded variant.
    """
    v, cfg = _lookup(vc)
    blocks: dict[str, list[DeriveBlock]] = {"enc": [], "mac": []}
    for counter in cfg.counters:
        for usage_label, usage in [("enc", v.usage_enc),
                                   ("mac", v.usage_mac)]:
            raw_data = bytes([counter]) + usage + b"\x00" + cfg.algo + cfg.keybits
            pad = v.block_size - (len(raw_data) % v.block_size)
            has_padding = pad != v.block_size
            padded = psec.mac.pad_iso_2(raw_data, v.block_size) if has_padding else raw_data
            blocks[usage_label].append(DeriveBlock(
                counter=counter,
                usage_label=usage_label,
                raw=raw_data,
                padded=padded,
                has_padding=has_padding,
            ))
    return blocks


def do_tr31_derive_data() -> list[DeriveData]:
    result: list[DeriveData] = []
    for version_id, v in _VERSIONS.items():
        if v.method != "cmac":
            continue
        for kbpk_bytes in v.kbpk_configs:
            vc = VersionCfg(version_id, kbpk_bytes)
            result.append(DeriveData(vc=vc, blocks=_derive_data_blocks_once(vc)))
    return result


def cmd_tr31_derive_data(args: argparse.Namespace) -> None:
    for d in do_tr31_derive_data():
        v, cfg = _lookup(d.vc)
        print(
            f"version {v.version_id} | cipher={v.algorithm} | "
            f"{cfg.description} | kbpk={cfg.kbpk_bytes}bytes | "
            f"subkey={v.subkey} | calls={len(cfg.counters)}"
        )
        print(f"  block_size={v.block_size}")
        print(f"    algo={cfg.algo.hex().upper()}  keybits={cfg.keybits.hex().upper()}")
        for b in d.blocks["enc"]:
            print(
                f"      counter={b.counter}  "
                f"usage_enc=({v.usage_enc.hex().upper()}): "
                f"=> {b.padded.hex().upper()}"
            )
        for b in d.blocks["mac"]:
            print(
                f"      counter={b.counter}  "
                f"usage_mac=({v.usage_mac.hex().upper()}): "
                f"=> {b.padded.hex().upper()}"
            )


# ---------------------------------------------------------------------------
# manual KBEK/KBAK derivation (via cmac / xvariant)
# ---------------------------------------------------------------------------

@dataclass
class CmacWorkKeyResult(WorkKeyResult):
    subkey_name: str = ""
    subkey: bytes = b""
    passes: dict[str, list[dict[str, bytes]]] = field(
        default_factory=lambda: {"enc": [], "mac": []},
    )
    # "enc" | "mac" -> list of {"xor": ..., "cmac": ...} per counter


def _gen_work_keycmac_once(kbpk: bytes, version_id: VersionId) -> CmacWorkKeyResult:
    """Derive KBEK/KBAK for a single CMAC version.

    Applies standard NIST CMAC to the raw (unpadded) derivation input
    blocks obtained from ``_derive_data_blocks_once``.
    """
    vc = VersionCfg(version_id, len(kbpk))
    v, cfg = _lookup(vc)
    k1, k2 = _derive_cmac_subkey_once(kbpk, v.algorithm)

    data_blocks = _derive_data_blocks_once(vc)

    trace = CmacWorkKeyResult(
        version_id=v.version_id,
        description=cfg.description,
        subkey_name=v.subkey,
        subkey=k1 if v.subkey == "K1" else k2,
    )
    result = trace
    workkey: dict[str, bytes] = {"enc": b"", "mac": b""}
    for usage_label in ("enc", "mac"):
        for b in data_blocks[usage_label]:
            pass_bytes = _cmac_once(kbpk, b.raw, v.algorithm)

            last_subkey = k2 if b.has_padding else k1
            xor_bytes = psec.tools.xor(b.padded, last_subkey)

            trace.passes[usage_label].append({"xor": xor_bytes, "cmac": pass_bytes})
            workkey[usage_label] += pass_bytes

    for v in workkey.values():
        assert len(v) >= len(kbpk)
    result.kbek = workkey["enc"][:len(kbpk)]
    result.kbak = workkey["mac"][:len(kbpk)]
    return result


def do_tr31_gen_work_key_cmac(kbpk: bytes) -> dict[VersionId, CmacWorkKeyResult]:
    acc: dict[VersionId, CmacWorkKeyResult] = {}
    for version_id, v in _VERSIONS.items():
        if v.method != "cmac":
            continue
        if len(kbpk) not in v.kbpk_configs:
            continue
        acc[version_id] = _gen_work_keycmac_once(kbpk, version_id)
    return acc


def _gen_work_keyxvariant_once(kbpk: bytes, version_id: VersionId) -> WorkKeyResult:
    """Derive KBEK/KBAK for a single XOR-variant version."""
    v = _VERSIONS[version_id]
    bek = psec.tools.xor(kbpk, b"\x45" * len(kbpk))
    bak = psec.tools.xor(kbpk, b"\x4D" * len(kbpk))
    return WorkKeyResult(version_id, v.description, kbek=bek, kbak=bak)


def do_tr31_gen_work_key_xvariant(kbpk: bytes) -> dict[VersionId, WorkKeyResult]:
    rows: dict[VersionId, WorkKeyResult] = {}
    for v in _VERSIONS.values():
        if v.method != "xvariant":
            continue
        rows[v.version_id] = _gen_work_keyxvariant_once(kbpk, v.version_id)
    return rows


# ---------------------------------------------------------------------------
# kbek-kbak  (compare manual derivation with library)
# ---------------------------------------------------------------------------

def cmd_tr31_kbek_kbak(args: argparse.Namespace) -> None:
    kbpk = bytes.fromhex(args.kbpk)
    print(f"kbpk: {kbpk.hex().upper()} ({len(kbpk)} bytes)\n")

    lib = do_tr31_gen_work_key_lib(kbpk)
    cmac = do_tr31_gen_work_key_cmac(kbpk)
    xvariant = do_tr31_gen_work_key_xvariant(kbpk)

    for version_id, r in cmac.items():
        print(f"version {r.version_id} | {r.description}:")
        print(f"  {r.subkey_name} -> {r.subkey.hex().upper()}")
        for usage_label in ("enc", "mac"):
            for i, p in enumerate(r.passes[usage_label], 1):
                print(f"  kd[{i}]{usage_label}: {p['xor'].hex().upper()}  --CMAC--> {p['cmac'].hex().upper()}")
        print(f"  => kbek: {r.kbek.hex().upper()}")
        print(f"  => kbak: {r.kbak.hex().upper()}")

        l = lib[version_id]
        if l.error is None:
            ok_bek = "(OK)" if r.kbek == l.kbek else "(MISMATCH)"
            ok_bak = "(OK)" if r.kbak == l.kbak else "(MISMATCH)"
            print(f"     lib kbek: {l.kbek.hex().upper()}  {ok_bek}")
            print(f"     lib kbak: {l.kbak.hex().upper()}  {ok_bak}")
        else:
            print("     lib: n/a")
        print()

    for version_id, r in xvariant.items():
        l = lib[version_id]
        if l.error is not None:
            continue
        print(f"version {r.version_id} | XOR variant:")
        ok_bek = "(OK)" if r.kbek == l.kbek else "(MISMATCH)"
        ok_bak = "(OK)" if r.kbak == l.kbak else "(MISMATCH)"
        print(f"  => kbek: {r.kbek.hex().upper()}  {ok_bek}  (kbpk ^ 0x45..45)")
        print(f"  => kbak: {r.kbak.hex().upper()}  {ok_bak}  (kbpk ^ 0x4D..4D)\n")


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="psec-tool",
        description="CLI over the psec payment-security library.",
    )
    subcmds = parser.add_subparsers(dest="command", required=True)

    tr31 = subcmds.add_parser("tr31", help="TR-31 key block operations.")
    tr31_sub = tr31.add_subparsers(dest="tr31_command", required=True)

    unwrap = tr31_sub.add_parser("unwrap", help="Unwrap a key from a TR-31 key block.")
    unwrap.add_argument(
        "-k", "--kbpk",
        help="Key Block Protection Key as a hex string. "
        "If omitted, only the header is parsed (no decryption or MAC check).",
    )
    unwrap.add_argument("key_block", help="TR-31 key block string to unwrap.")
    unwrap.set_defaults(func=cmd_tr31_unwrap)

    wrap = tr31_sub.add_parser("wrap", help="Wrap a key into a TR-31 key block.")
    wrap.add_argument(
        "-k", "--kbpk", required=True,
        help="Key Block Protection Key as a hex string.",
    )
    wrap.add_argument(
        "header",
        help="TR-31 key block header string (e.g. B0096P0TE00N0000).",
    )
    wrap.add_argument(
        "key",
        help="Key to wrap as a hex string.",
    )
    wrap.add_argument(
        "-m", "--masked-key-len", type=int, default=None,
        help="Desired key length in bytes to mask true key length.",
    )
    wrap.set_defaults(func=cmd_tr31_wrap)

    kbpk = tr31_sub.add_parser("kbpk", help="Derive KBEK/KBAK for all versions (via library).")
    kbpk.add_argument("-k", "--kbpk", required=True, help="Key Block Protection Key as a hex string.")
    kbpk.set_defaults(func=cmd_tr31_kbpk)

    cmac_k1k2 = tr31_sub.add_parser("cmac-k1k2", help="Derive CMAC subkeys K1/K2.")
    cmac_k1k2.add_argument("key", help="Key as a hex string.")
    cmac_k1k2.set_defaults(func=cmd_tr31_cmac_k1k2)

    cmac = tr31_sub.add_parser("cmac", help="Compute CMAC (NIST SP 800-38B).")
    cmac.add_argument("key", help="Key as a hex string.")
    cmac.add_argument("data", help="Data to authenticate as a hex string.")
    cmac.add_argument("algo", choices=["TDES", "AES"], help="Block cipher algorithm.")
    cmac.set_defaults(func=cmd_tr31_cmac)

    derive_data = tr31_sub.add_parser("derive-data", help="Derivation input data blocks for CMAC versions.")
    derive_data.set_defaults(func=cmd_tr31_derive_data)

    kbek_kbak = tr31_sub.add_parser("kbek-kbak", help="Manual KBEK/KBAK derivation with library comparison.")
    kbek_kbak.add_argument("-k", "--kbpk", required=True, help="Key Block Protection Key as a hex string.")
    kbek_kbak.set_defaults(func=cmd_tr31_kbek_kbak)

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    try:
        args.func(args)
    except (ValueError, psec.tr31.KeyBlockError, psec.tr31.HeaderError) as e:
        print(f"error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()

