# ---------------------------------------------------------------------------
# unified version definitions
# ---------------------------------------------------------------------------

class Algorithm(Enum):
    TDES = "TDES"
    AES = "AES"

    def __str__(self) -> str:
        return self.value

    @property
    def block_size(self) -> int:
        return 8 if self is Algorithm.TDES else 16

    @property
    def mac_algorithm(self) -> "psec.mac.Algorithm":
        return _ALGO_TO_MAC[self]


_ALGO_TO_MAC: dict["Algorithm", "psec.mac.Algorithm"] = {
    Algorithm.TDES: psec.mac.Algorithm.DES,
    Algorithm.AES: psec.mac.Algorithm.AES,
}


class VersionId(str, Enum):
    A = "A"
    B = "B"
    C = "C"
    D = "D"
    E = "E"

    def __str__(self) -> str:
        return self.value


@dataclass
class KbpkConfig:
    """One valid KBPK length and its kd_input parameters.

    Maps to bytes 4-7 of the CMAC derivation input block:

        byte 0    : counter (1, 2, …)
        byte 1-2  : key usage indicator
        byte 3    : separator (always 0x00)
        byte 4-5  : algorithm indicator → ``algo``
        byte 6-7  : key length in bits    → ``keybits``
        bytes 8.. : zero-padding to reach the version's block_size
    """

    kbpk_bytes: int
    """KBPK key length in bytes (e.g. 16 for 2-key TDES or AES-128)."""

    description: str
    """Human-readable label (``"2-key"``, ``"AES-256"``, etc.)."""

    algo: bytes
    """Algorithm indicator, 2 bytes (``b"\\x00\\x00"`` = 2-key TDES,
    ``b"\\x00\\x04"`` = AES-256, etc.)."""

    keybits: bytes
    """Key length in bits, 2 bytes (``b"\\x00\\x80"`` = 128 bits,
    ``b"\\x01\\x00"`` = 256 bits, etc.)."""

    counters: list[int]
    """CMAC counter values (starting at 1).  One pass per counter
    yields 64 bits (TDES) or 128 bits (AES) of keying material."""


@dataclass
class Tr31Version:
    """One TR-31 version — covers all five version IDs (A-E).

    Versions A/C use XOR-variant derivation (``method="xvariant"``).
    Versions B/D/E use CMAC-based derivation (``method="cmac"``).

    Derivation procedure for CMAC versions:
      1.  Derive CMAC subkey from KBPK: K1 (TDES) or K2 (AES).
      2.  For each counter in ``counters``:
          a. Set byte 0 = counter.
          b. Set bytes 1-2 = usage.
          c. XOR the full kd_input block with the subkey.
          d. Run CBC-MAC (IV=0 → ECB on one block) under KBPK.
          e. Each call yields 64 bits (TDES) or 128 bits (AES).
      3.  Concatenate passes, truncate to KBPK length:
            usage_enc → KBEK   usage_mac → KBAK
    """

    version_id: VersionId
    """TR-31 version letter (``"A"``-``"E"``)."""

    description: str
    """Full description (e.g. ``"TDES Key Derivation Binding Method"``)."""

    method: str
    """``"xvariant"`` or ``"cmac"``."""

    algorithm: Algorithm | None = None
    """Block cipher family.  ``None`` for xvariant."""

    block_size: int = 0
    """Encryption block size in bytes (8 | 16). 0 for xvariant."""

    subkey: str = ""
    """CMAC subkey used for masking (``"K1"`` | ``"K2"``). Empty for xvariant."""

    usage_enc: bytes = b""
    """Usage indicator for KBEK, 2 bytes (``b"\\x00\\x00"`` | ``b"\\x00\\x02"``)."""

    usage_mac: bytes = b""
    """Usage indicator for KBAK, 2 bytes (``b"\\x00\\x01"``)."""

    kbpk_configs: dict[int, KbpkConfig] = field(default_factory=dict)
    """Valid KBPK lengths (CMAC versions only). Keyed by ``kbpk_bytes``."""


_VERSIONS: dict[VersionId, Tr31Version] = {
    VersionId.A: Tr31Version(
        version_id=VersionId.A, description="TDES Key Variant Binding Method",
        method="xvariant",
    ),
    VersionId.B: Tr31Version(
        version_id=VersionId.B, description="TDES Key Derivation Binding Method",
        method="cmac",
        algorithm=Algorithm.TDES, block_size=8, subkey="K1",
        usage_enc=bytes.fromhex("0000"), usage_mac=bytes.fromhex("0001"),
        kbpk_configs={
            16: KbpkConfig(16, "2-key", bytes.fromhex("0000"), bytes.fromhex("0080"), [1, 2]),
            24: KbpkConfig(24, "3-key", bytes.fromhex("0001"), bytes.fromhex("00C0"), [1, 2, 3]),
        },
    ),
    VersionId.C: Tr31Version(
        version_id=VersionId.C, description="TDES Key Variant Binding Method",
        method="xvariant",
    ),
    VersionId.D: Tr31Version(
        version_id=VersionId.D, description="AES Key Derivation Binding Method",
        method="cmac",
        algorithm=Algorithm.AES, block_size=16, subkey="K2",
        usage_enc=bytes.fromhex("0000"), usage_mac=bytes.fromhex("0001"),
        kbpk_configs={
            16: KbpkConfig(16, "AES-128", bytes.fromhex("0002"), bytes.fromhex("0080"), [1]),
            24: KbpkConfig(24, "AES-192", bytes.fromhex("0003"), bytes.fromhex("00C0"), [1, 2]),
            32: KbpkConfig(32, "AES-256", bytes.fromhex("0004"), bytes.fromhex("0100"), [1, 2]),
        },
    ),
    VersionId.E: Tr31Version(
        version_id=VersionId.E, description="AES Key Derivation Binding Method",
        method="cmac",
        algorithm=Algorithm.AES, block_size=16, subkey="K2",
        usage_enc=bytes.fromhex("0002"), usage_mac=bytes.fromhex("0001"),
        kbpk_configs={
            16: KbpkConfig(16, "AES-128", bytes.fromhex("0002"), bytes.fromhex("0080"), [1]),
            24: KbpkConfig(24, "AES-192", bytes.fromhex("0003"), bytes.fromhex("00C0"), [1, 2]),
            32: KbpkConfig(32, "AES-256", bytes.fromhex("0004"), bytes.fromhex("0100"), [1, 2]),
        },
    ),
}


@dataclass(frozen=True)
class VersionCfg:
    """Canonical key into ``_VERSIONS`` / ``kbpk_configs``."""
    version_id: VersionId
    kbpk_bytes: int


def _lookup(vc: VersionCfg) -> tuple[Tr31Version, KbpkConfig]:
    """Resolve a ``VersionCfg`` to its full objects."""
    v = _VERSIONS[vc.version_id]
    return v, v.kbpk_configs[vc.kbpk_bytes]


