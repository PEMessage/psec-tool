_VERSION_LABELS: dict[str, str] = {
    "A": "TDES variant (deprecated)",
    "B": "TDES CMAC key derivation (preferred)",
    "C": "TDES variant (same as A)",
    "D": "AES CMAC key derivation",
    "E": "AES CMAC key derivation (ISO 20038, CTR)",
}

_ALGO_MAX_KEY_LEN: dict[str, int] = {"T": 24, "D": 24, "A": 32}


def do_tr31_wrap_verbose(
    kbpk: bytes, header_str: str, key: bytes,
    masked_key_len: int | None = None,
    padding_mode: str = "zero",
) -> tuple[str, dict[str, object]]:
    hdr = psec.tr31.Header()
    hdr.load(header_str)
    ver = hdr.version_id
    if ver not in _WRAPV_DISPATCH:
        raise ValueError(f"wrap-verbose does not support version '{ver}'")
    img: dict[str, object] = {}
    img["version_id"] = ver
    img["padding_mode"] = padding_mode

    if masked_key_len is None:
        masked_key_len = max(_ALGO_MAX_KEY_LEN.get(hdr.algorithm, len(key)), len(key))
    else:
        masked_key_len = max(masked_key_len, len(key))
    extra_pad = masked_key_len - len(key)
    img["masked_key_len"] = masked_key_len
    img["extra_pad"] = extra_pad

    header_dump = _wrapv_build_header(hdr, masked_key_len)
    img["header_dump"] = header_dump

    inner = _WRAPV_DISPATCH[ver](kbpk, header_dump, key, extra_pad, padding_mode)
    img.update(inner)

    return img["key_block"], img


def cmd_tr31_wrap_verbose(args: argparse.Namespace) -> None:
    kbpk = bytes.fromhex(args.kbpk)
    key = bytes.fromhex(args.key)

    try:
        key_block, img = do_tr31_wrap_verbose(
            kbpk, args.header, key, args.masked_key_len, args.padding,
        )
    except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
        print(f"error: {e}", file=sys.stderr)
        sys.exit(1)

    ver = img["version_id"]
    label = _VERSION_LABELS.get(ver, "unknown")
    print(f"=== TR-31 Version {ver} Key Wrap ({label}) ===\n")

    print("--- Inputs ---")
    print(f"KBPK:              {kbpk.hex().upper()} ({len(kbpk)} bytes)")
    print(f"Header (input):    {args.header}")
    print(f"Key:               {key.hex().upper()} ({len(key)} bytes)")
    ml = img["masked_key_len"]
    default_note = f"  (default: max({_ALGO_MAX_KEY_LEN.get(ver, '?')}, {len(key)}))" if args.masked_key_len is None else ""
    print(f"Masked key len:    {ml} bytes{default_note}")
    pm = img.get("padding_mode", "zero")
    print(f"Padding mode:      {pm} ({'os.urandom' if pm == 'random' else 'zero-fill'})")
    print()

    hdr_tmp = psec.tr31.Header()
    hdr_tmp.load(args.header)
    print("--- Parsed Header Fields ---")
    print(f"version_id:        {hdr_tmp.version_id}")
    print(f"key_usage:         {hdr_tmp.key_usage}")
    print(f"algorithm:         {hdr_tmp.algorithm}")
    print(f"mode_of_use:       {hdr_tmp.mode_of_use}")
    print(f"version_num:       {hdr_tmp.version_num}")
    print(f"exportability:     {hdr_tmp.exportability}")
    print(f"reserved:          {hdr_tmp.reserved}")
    if hdr_tmp.blocks:
        print(f"optional blocks:   {len(hdr_tmp.blocks)}")
        for bid, bdata in hdr_tmp.blocks.items():
            print(f"  {bid}: {bdata}")
    print()

    print("--- Header String (dump) ---")
    print(f"  {img['header_dump']}")
    print()

    # --- Key derivation ---
    method = img.get("method")
    if method == "variant":
        print("--- Key Derivation (variant) ---")
        print(f"KBPK:              {kbpk.hex().upper()}")
        print(f"variant_enc (0x45): {img['variant_enc'].hex().upper()}")
        print(f"  => KBEK (XOR):   {img['kbek'].hex().upper()}")
        print(f"variant_mac (0x4D): {img['variant_mac'].hex().upper()}")
        print(f"  => KBAK (XOR):   {img['kbak'].hex().upper()}")
        print()
    elif method == "cmac":
        algo = img["algorithm"]
        print(f"--- Key Derivation (CMAC, {algo}) ---")
        print(f"KBPK:              {kbpk.hex().upper()}")
        subkey_name = img["subkey_name"]
        print(f"CMAC subkey ({subkey_name}): {img['subkey'].hex().upper()}")
        for usage_label in ("enc", "mac"):
            for i, p in enumerate(img["cmac_passes"][usage_label], 1):
                print(f"  kd[{i}]{usage_label}: {p['xor'].hex().upper()}  --CMAC--> {p['cmac'].hex().upper()}")
        print(f"  => KBEK:         {img['kbek'].hex().upper()}")
        print(f"  => KBAK:         {img['kbak'].hex().upper()}")
        print()
    else:
        print("--- Key Derivation ---")
        print(f"KBEK:              {img['kbek'].hex().upper()}")
        print(f"KBAK:              {img['kbak'].hex().upper()}")
        print()

    # --- Clear key data ---
    print("--- Clear Key Data ---")
    print(f"key_len_bits:      {img['key_len_bits'].hex().upper()}  "
          f"({int.from_bytes(img['key_len_bits'], 'big')} bits = {len(key)} bytes)")
    print(f"key (payload):     {key.hex().upper()}  ({len(key)} bytes)")
    print(f"extra_pad:         {img['extra_pad']} bytes  (length masking)")
    print(f"pad_len:           {img['pad_len']} bytes  (block alignment)")
    total_pad = img["total_pad"]
    print(f"total_pad:         {total_pad} bytes")
    if total_pad > 0:
        print(f"padding:           {'00' * total_pad}")
    else:
        print(f"padding:           (none)")
    print(f"clear_key_data:    {img['clear_key_data'].hex().upper()}  "
          f"({len(img['clear_key_data'])} bytes)")
    print()

    # --- Encryption ---
    if ver in ("A", "C", "B"):
        cipher = "TDES-CBC"
    elif ver == "D":
        cipher = "AES-CBC"
    else:
        cipher = "AES-CTR"
    print(f"--- Encryption ({cipher}) ---")
    print(f"KBEK:              {img['kbek'].hex().upper()}")
    if ver in ("A", "C"):
        iv_str = img["iv"].decode("ascii")
        print(f"IV (header[:8]):   {img['iv'].hex().upper()}  (= \"{iv_str}\")")
    elif ver == "E":
        print(f"Nonce (MAC):       {img['nonce'].hex().upper()}")
    else:
        print(f"IV (MAC):          {img['iv_mac'].hex().upper()}")
    print(f"clear_key_data:    {img['clear_key_data'].hex().upper()}")
    print(f"enc_key:           {img['enc_key'].hex().upper()}  "
          f"({len(img['enc_key'])} bytes)")
    print()

    # --- MAC ---
    print("--- MAC Generation ---")
    print(f"KBAK:              {img['kbak'].hex().upper()}")
    if ver in ("A", "C"):
        print(f"MAC input:         header (ascii) + enc_key (bytes)")
        print(f"  header (ascii):  {img['header_dump']}")
        print(f"  + enc_key (hex): {img['enc_key'].hex().upper()}")
        print(f"  = MAC data:      {img['mac_data_bytes'].hex().upper()}")
        print(f"CBC-MAC:           MAC = CBC-MAC(KBAK, MAC data, padding=1, len=4, DES)")
        mac_len = 4
    elif ver == "B":
        print(f"CMAC K1 of KBAK:   {img['mac_k1'].hex().upper()}")
        print(f"MAC data:          header || clear_key_data")
        print(f"  header:          {img['header_dump']}")
        print(f"  + ckd (hex):     {img['clear_key_data'].hex().upper()}")
        print(f"  = full:          {img['mac_data_full'].hex().upper()}")
        print(f"  XOR last 8:      {img['mac_data_xor'].hex().upper()}")
        print(f"CBC-MAC:           MAC = CBC-MAC(KBAK, xor_data, padding=1, len=8, DES)")
        mac_len = 8
    elif ver == "D":
        print(f"CMAC K1 of KBAK:   {img['mac_k1'].hex().upper()}")
        print(f"MAC data:          header || clear_key_data")
        print(f"  header:          {img['header_dump']}")
        print(f"  + ckd (hex):     {img['clear_key_data'].hex().upper()}")
        print(f"  = full:          {img['mac_data_full'].hex().upper()}")
        print(f"  XOR last 16:     {img['mac_data_xor'].hex().upper()}")
        print(f"CBC-MAC:           MAC = CBC-MAC(KBAK, xor_data, padding=1, len=16, AES)")
        mac_len = 16
    else:
        padded_note = " (padded)" if img.get("mac_padded") else " (exact block)"
        print(f"CMAC K1 of KBAK:   {img['mac_k1'].hex().upper()}")
        print(f"CMAC K2 of KBAK:   {img['mac_k2'].hex().upper()}")
        print(f"MAC data:          header || clear_key_data")
        print(f"  header:          {img['header_dump']}")
        print(f"  + ckd (hex):     {img['clear_key_data'].hex().upper()}")
        print(f"  = full:          {img['mac_data_full'].hex().upper()}{padded_note}")
        print(f"  XOR last 16:     {img['mac_data_xor'].hex().upper()}")
        print(f"CBC-MAC:           MAC = CBC-MAC(KBAK, xor_data, padding=1, len=16, AES)")
        mac_len = 16
    print(f"MAC:               {img['mac'].hex().upper()}  ({mac_len} bytes)")
    print()

    print("--- Final Key Block ---")
    print(f"  {img['key_block']}")
    print()

    try:
        lib_kb = psec.tr31.wrap(
            kbpk=kbpk, header=args.header, key=key,
            masked_key_len=args.masked_key_len,
        )
        print("--- Cross-check ---")
        print(f"Library wrap:      {lib_kb}")

        kb_obj = psec.tr31.KeyBlock(kbpk=kbpk)
        try:
            unwrapped = kb_obj.unwrap(img["key_block"])
            ok_self = "OK" if unwrapped == key else "MISMATCH"
            print(f"Self-unwrap:       {unwrapped.hex().upper()}  ({ok_self})")
        except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
            print(f"Self-unwrap:       FAILED  ({e})")

        kb_obj2 = psec.tr31.KeyBlock(kbpk=kbpk)
        try:
            lib_unwrapped = kb_obj2.unwrap(lib_kb)
            ok_lib = "OK" if lib_unwrapped == key else "MISMATCH"
            print(f"Library-unwrap:    {lib_unwrapped.hex().upper()}  ({ok_lib})")
        except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
            print(f"Library-unwrap:    FAILED  ({e})")
    except (psec.tr31.KeyBlockError, psec.tr31.HeaderError, ValueError) as e:
        print(f"Library wrap: n/a  ({e})")


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="psec-tool",
        description="CLI over the psec payment-security library.",
    )
    subcmds = parser.add_subparsers(dest="command", required=True)

    tr31 = subcmds.add_parser("tr31", help="TR-31 key block operations.")
    tr31_sub = tr31.add_subparsers(dest="tr31_command", required=True)

    unwrap = tr31_sub.add_parser("unwrap", help="Unwrap a key from a TR-31 key block.")
    unwrap.add_argument(
        "-k", "--kbpk",
        help="Key Block Protection Key as a hex string. "
        "If omitted, only the header is parsed (no decryption or MAC check).",
    )
    unwrap.add_argument("key_block", help="TR-31 key block string to unwrap.")
    unwrap.set_defaults(func=cmd_tr31_unwrap)

    wrap = tr31_sub.add_parser("wrap", help="Wrap a key into a TR-31 key block.")
    wrap.add_argument(
        "-k", "--kbpk", required=True,
        help="Key Block Protection Key as a hex string.",
    )
    wrap.add_argument(
        "header",
        help="TR-31 key block header string (e.g. B0096P0TE00N0000).",
    )
    wrap.add_argument(
        "key",
        help="Key to wrap as a hex string.",
    )
    wrap.add_argument(
        "-m", "--masked-key-len", type=int, default=None,
        help="Desired key length in bytes to mask true key length.",
    )
    wrap.set_defaults(func=cmd_tr31_wrap)

    gen_header = tr31_sub.add_parser("gen-header", help="Generate a TR-31 key block header string.")
    gen_header.add_argument(
        "-i", "--interactive", action="store_true",
        help="Prompt for each field interactively. "
        "Other options provide the defaults; prompted blocks are appended to -b.",
    )
    gen_header.add_argument(
        "-v", "--version-id", default="B", choices=["A", "B", "C", "D", "E"],
        help="Key block version ID: A/C=TDES variant (deprecated), "
        "B=TDES key derivation (preferred), D=AES key derivation, "
        "E=AES key derivation (ISO 20038). Default: B.",
    )
    gen_header.add_argument(
        "-u", "--key-usage", default="00",
        help="Intended function of the key, 2 chars "
        "(e.g. P0=PIN encryption, M3=MAC, K0=KEK, D0=data encryption). Default: 00.",
    )
    gen_header.add_argument(
        "-a", "--algorithm", default="0",
        help="Approved algorithm for the protected key, 1 char "
        "(e.g. T=TDES, A=AES, D=DES, R=RSA, H=HMAC). Default: 0.",
    )
    gen_header.add_argument(
        "-m", "--mode-of-use", default="0",
        help="Operation the protected key can perform, 1 char "
        "(e.g. E=encrypt, D=decrypt, B=both, G=generate, V=verify, N=none). Default: 0.",
    )
    gen_header.add_argument(
        "-n", "--version-num", default="00",
        help="Key version number, 2 chars. Not to be confused with version ID. Default: 00.",
    )
    gen_header.add_argument(
        "-e", "--exportability", default="N",
        help="Whether the key may leave the cryptographic domain, 1 char "
        "(E=exportable, N=non-exportable, S=sensitive). Default: N.",
    )
    gen_header.add_argument(
        "-b", "--block", action="append", metavar="ID=DATA",
        help="Optional block as ID=DATA (e.g. KS=00604B120F9292800000). Repeatable.",
    )
    gen_header.add_argument(
        "-l", "--key-len", type=int, default=None,
        help="Length in bytes of the key to be wrapped. If given, the header "
        "length field reflects the final key block length; otherwise only the header itself.",
    )
    gen_header.set_defaults(func=cmd_tr31_gen_header)

    kbpk = tr31_sub.add_parser("kbpk", help="Derive KBEK/KBAK for all versions (via library).")
    kbpk.add_argument("-k", "--kbpk", required=True, help="Key Block Protection Key as a hex string.")
    kbpk.set_defaults(func=cmd_tr31_kbpk)

    cmac_k1k2 = tr31_sub.add_parser("cmac-k1k2", help="Derive CMAC subkeys K1/K2.")
    cmac_k1k2.add_argument("key", help="Key as a hex string.")
    cmac_k1k2.set_defaults(func=cmd_tr31_cmac_k1k2)

    cmac = tr31_sub.add_parser("cmac", help="Compute CMAC (NIST SP 800-38B).")
    cmac.add_argument("key", help="Key as a hex string.")
    cmac.add_argument("data", help="Data to authenticate as a hex string.")
    cmac.add_argument("algo", choices=["TDES", "AES"], help="Block cipher algorithm.")
    cmac.set_defaults(func=cmd_tr31_cmac)

    padding = tr31_sub.add_parser("padding", help="Show padded key-data block fed to TR-31 encryption.")
    padding.add_argument("-v", "--version", required=True, choices=["A", "B", "C", "D", "E"],
                         help="TR-31 version ID (determines block size).")
    padding.add_argument("-m", "--masked-key-len", type=int, default=None,
                         help="Masked key length in bytes (default: actual key length).")
    padding.add_argument("payload", help="Payload bytes as a hex string.")
    padding.set_defaults(func=cmd_tr31_padding)

    unpadding = tr31_sub.add_parser("unpadding", help="Extract key from a TR-31 clear-key-data block.")
    unpadding.add_argument("-v", "--version", required=True, choices=["A", "B", "C", "D", "E"],
                           help="TR-31 version ID (informational, does not affect extraction).")
    unpadding.add_argument("clear_key_data", help="Clear key data hex (key-len-bits + key + padding).")
    unpadding.set_defaults(func=cmd_tr31_unpadding)

    derive_data = tr31_sub.add_parser("derive-data", help="Derivation input data blocks for CMAC versions.")
    derive_data.set_defaults(func=cmd_tr31_derive_data)

    kbek_kbak = tr31_sub.add_parser("kbek-kbak", help="Manual KBEK/KBAK derivation with library comparison.")
    kbek_kbak.add_argument("-k", "--kbpk", required=True, help="Key Block Protection Key as a hex string.")
    kbek_kbak.set_defaults(func=cmd_tr31_kbek_kbak)

    wrapv = tr31_sub.add_parser("wrap-verbose", help="Verbose TR-31 key wrap with all intermediate values (versions A-E).")
    wrapv.add_argument("-k", "--kbpk", required=True, help="Key Block Protection Key as a hex string.")
    wrapv.add_argument("header", help="TR-31 key block header string.")
    wrapv.add_argument("key", help="Key to wrap as a hex string.")
    wrapv.add_argument(
        "-m", "--masked-key-len", type=int, default=None,
        help="Desired key length in bytes to mask true key length.",
    )
    wrapv.add_argument(
        "--padding", default="zero", choices=["zero", "random"],
        help="Padding style: zero (deterministic 0x00 fill) or random (os.urandom, matches library).",
    )
    wrapv.set_defaults(func=cmd_tr31_wrap_verbose)

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    try:
        args.func(args)
    except (ValueError, psec.tr31.KeyBlockError, psec.tr31.HeaderError) as e:
        print(f"error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()

